{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "yahala-usa-linktree-atlas-preview",
  "main": "./src/worker.js",
  "compatibility_date": "2026-06-09",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true,
  },
}
