---
import '../styles.css'

import { Icon } from 'astro-icon/components'

import FeaturedEpisodes from '../components/FeaturedEpisodes.astro'
import LatestChannelVideo from '../components/LatestChannelVideo.astro'
import Link from '../components/Link.astro'
import QrCodeButton from '../components/QrCodeButton.astro'
import ReachBadge from '../components/ReachBadge.astro'
import TopicCards from '../components/TopicCards.astro'
import SocialLinkButton from '../components/SocialLinkButton'
import VideoBentoGrid from '../components/VideoBentoGrid.astro'
import VisitedPlacesMap from '../components/VisitedPlacesMap.astro'
import heroCover from '../assets/yahala-hero-cover.png'
import latestYoutubeVideos from '../data/latest-youtube-videos.json'
import {
  getBaseUrl,
  resolveSiteAsset,
  siteConfig,
} from '../lib/site-config'

const {
  pageTitle,
  pageDescription,
  siteName,
  profileName,
  twitterHandle,
  heroImageAlt,
  profileImage,
  ogImage,
} = siteConfig.site
const { socialLinks, youtubeChannels, socialReach, visitedPlaces } = siteConfig
const baseUrl = getBaseUrl(import.meta.env.BASE_URL)
const profileImageUrl = resolveSiteAsset(baseUrl, profileImage)
const currentYear = new Date().getFullYear()
const canonicalUrl = new URL(baseUrl, Astro.site).toString()
const sitemapUrl = new URL(`${baseUrl}sitemap-index.xml`, Astro.site).toString()
const heroImagePath = heroCover.src
const heroImageUrl = new URL(
  resolveSiteAsset(baseUrl, ogImage),
  Astro.site,
).toString()

const latestVideoChannels = youtubeChannels.filter((channel) =>
  Boolean(latestYoutubeVideos[channel.id]),
)
const totalReach = socialReach.items.reduce((sum, item) => sum + item.value, 0)
const channelBranding = Object.fromEntries(
  youtubeChannels.map((channel) => [
    channel.id,
    {
      ...channel.branding,
      logoSrc:
        channel.branding?.logoSrc === 'profileImage'
          ? profileImageUrl
          : (channel.branding?.logoSrc ?? profileImageUrl),
    },
  ]),
)

const instagramLink = socialLinks.find((link) => link.id === 'instagram')
const sameAsUrls = socialLinks.map((link) => link.url)
const socialIconBodies = {
  youtube:
    '<path fill="currentColor" d="M23.498 6.186a3.02 3.02 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.02 3.02 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.02 3.02 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.02 3.02 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814M9.545 15.568V8.432L15.818 12z"/>',
  tiktok:
    '<path fill="currentColor" d="M12.525.02c1.31-.02 2.61-.01 3.91-.02c.08 1.53.63 3.09 1.75 4.17c1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97c-.57-.26-1.1-.59-1.62-.93c-.01 2.92.01 5.84-.02 8.75c-.08 1.4-.54 2.79-1.35 3.94c-1.31 1.92-3.58 3.17-5.91 3.21c-1.43.08-2.86-.31-4.08-1.03c-2.02-1.19-3.44-3.37-3.65-5.71c-.02-.5-.03-1-.01-1.49c.18-1.9 1.12-3.72 2.58-4.96c1.66-1.44 3.98-2.13 6.15-1.72c.02 1.48-.04 2.96-.04 4.44c-.99-.32-2.15-.23-3.02.37c-.63.41-1.11 1.04-1.36 1.75c-.21.51-.15 1.07-.14 1.61c.24 1.64 1.82 3.02 3.5 2.87c1.12-.01 2.19-.66 2.77-1.61c.19-.33.4-.67.41-1.06c.1-1.79.06-3.57.07-5.36c.01-4.03-.01-8.05.02-12.07"/>',
  instagram:
    '<path fill="currentColor" d="M7.03.084c-1.277.06-2.149.264-2.91.563a5.9 5.9 0 0 0-2.124 1.388a5.9 5.9 0 0 0-1.38 2.127C.321 4.926.12 5.8.064 7.076s-.069 1.688-.063 4.947s.021 3.667.083 4.947c.061 1.277.264 2.149.563 2.911c.308.789.72 1.457 1.388 2.123a5.9 5.9 0 0 0 2.129 1.38c.763.295 1.636.496 2.913.552c1.278.056 1.689.069 4.947.063s3.668-.021 4.947-.082c1.28-.06 2.147-.265 2.91-.563a5.9 5.9 0 0 0 2.123-1.388a5.9 5.9 0 0 0 1.38-2.129c.295-.763.496-1.636.551-2.912c.056-1.28.07-1.69.063-4.948c-.006-3.258-.02-3.667-.081-4.947c-.06-1.28-.264-2.148-.564-2.911a5.9 5.9 0 0 0-1.387-2.123a5.9 5.9 0 0 0-2.128-1.38c-.764-.294-1.636-.496-2.914-.55C15.647.009 15.236-.006 11.977 0S8.31.021 7.03.084m.14 21.693c-1.17-.05-1.805-.245-2.228-.408a3.7 3.7 0 0 1-1.382-.895a3.7 3.7 0 0 1-.9-1.378c-.165-.423-.363-1.058-.417-2.228c-.06-1.264-.072-1.644-.08-4.848c-.006-3.204.006-3.583.061-4.848c.05-1.169.246-1.805.408-2.228c.216-.561.477-.96.895-1.382a3.7 3.7 0 0 1 1.379-.9c.423-.165 1.057-.361 2.227-.417c1.265-.06 1.644-.072 4.848-.08c3.203-.006 3.583.006 4.85.062c1.168.05 1.804.244 2.227.408c.56.216.96.475 1.382.895s.681.817.9 1.378c.165.422.362 1.056.417 2.227c.06 1.265.074 1.645.08 4.848c.005 3.203-.006 3.583-.061 4.848c-.051 1.17-.245 1.805-.408 2.23c-.216.56-.477.96-.896 1.38a3.7 3.7 0 0 1-1.378.9c-.422.165-1.058.362-2.226.418c-1.266.06-1.645.072-4.85.079s-3.582-.006-4.848-.06m9.783-16.192a1.44 1.44 0 1 0 1.437-1.442a1.44 1.44 0 0 0-1.437 1.442M5.839 12.012a6.161 6.161 0 1 0 12.323-.024a6.162 6.162 0 0 0-12.323.024M8 12.008A4 4 0 1 1 12.008 16A4 4 0 0 1 8 12.008"/>',
  facebook:
    '<path fill="currentColor" d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978c.401 0 .955.042 1.468.103a9 9 0 0 1 1.141.195v3.325a9 9 0 0 0-.653-.036a27 27 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.7 1.7 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103l-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647"/>',
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${canonicalUrl}#profile-page`,
  url: canonicalUrl,
  name: pageTitle,
  description: pageDescription,
  image: heroImageUrl,
  inLanguage: 'en',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${canonicalUrl}#website`,
    url: canonicalUrl,
    name: siteName,
  },
  mainEntity: {
    '@type': 'Person',
    '@id': `${canonicalUrl}#person`,
    name: profileName,
    alternateName: siteName,
    description: pageDescription,
    image: profileImageUrl,
    url: canonicalUrl,
    sameAs: sameAsUrls,
  },
  significantLink: sameAsUrls,
}
---

<!doctype html>
<html lang="en" class="box-border">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />

    <link rel="icon" href={`${baseUrl}favicon.ico`} sizes="32x32" />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={`${baseUrl}favicon-16x16.png`}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${baseUrl}favicon-32x32.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${baseUrl}apple-touch-icon.png`}
    />
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <meta
      name="theme-color"
      content="#fafafa"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#18181b"
      media="(prefers-color-scheme: dark)"
    />

    <script is:inline>
      ;(() => {
        const lightThemeColor = '#ffffff'
        const darkThemeColor = '#1c1917'
        const systemQuery = window.matchMedia('(prefers-color-scheme: dark)')

        const applyTheme = () => {
          const isDark = systemQuery.matches
          const theme = isDark ? 'dark' : 'light'

          document.documentElement.classList.toggle('dark', isDark)
          document.documentElement.style.colorScheme = theme

          document
            .querySelectorAll('meta[name="theme-color"]')
            .forEach((meta) => {
              meta.content = isDark ? darkThemeColor : lightThemeColor
              meta.media = ''
            })
        }

        applyTheme()
      })()
    </script>

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={heroImageUrl} />
    <meta property="og:image:alt" content={heroImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={heroImageUrl} />
    <meta name="twitter:image:alt" content={heroImageAlt} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href={sitemapUrl} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body
    class="linktree-page my-0 min-h-screen text-center text-lg subpixel-antialiased"
  >
    <main class="linktree-shell mx-auto flex w-full flex-col pb-6">
      <section
        class="linktree-hero animate-fade-in-up"
        aria-labelledby="profile-title"
      >
        <button
          type="button"
          class="linktree-hero__share"
          aria-label="Share Ya Hala with Haithum"
          data-share-page
          data-share-title={pageTitle}
          data-share-text={pageDescription}
          data-share-url={canonicalUrl}
        >
          <Icon
            name="heroicons:arrow-up-tray"
            class="size-5"
            aria-hidden="true"
          />
        </button>
        <img
          src={heroImagePath}
          alt={heroImageAlt}
          class="linktree-hero__image"
          decoding="async"
          loading="eager"
        />
        <div class="linktree-hero__fade" aria-hidden="true"></div>
      </section>

      <h1
        id="profile-title"
        class="font-display animate-fade-in-up text-foreground mx-auto mt-5 mb-4 w-full max-w-xl px-4 text-4xl leading-none font-extrabold delay-100 [text-shadow:0_2px_12px_color-mix(in_oklch,var(--color-shadow)_18%,transparent)] sm:px-6 sm:text-5xl"
      >
        <span class="block">
          <span class="text-primary">Ya Hala</span> with Haithum
        </span>
        <span
          class="text-primary mt-2 block text-3xl leading-tight font-semibold [text-shadow:0_1px_8px_color-mix(in_oklch,var(--color-brand-600)_18%,transparent)] sm:mt-3 sm:text-4xl"
        >
          ياهلا مع هيثم
        </span>
      </h1>
      <p
        class="animate-fade-in-up text-muted-foreground mx-auto mb-4 w-full max-w-xl px-4 text-center text-lg leading-relaxed delay-200 sm:px-6 sm:text-xl"
      >
        {pageDescription}
      </p>

      <QrCodeButton />

      <VideoBentoGrid />

      <ReachBadge
        total={totalReach}
        updatedAt={socialReach.updatedAt}
        items={socialReach.items}
      />

      <FeaturedEpisodes />

      <VisitedPlacesMap visitedPlaces={visitedPlaces} />

      <section
        class="animate-fade-in-up mt-8 mb-5 flex flex-col gap-4 delay-400"
        aria-label="Latest YouTube video"
      >
        {
          latestVideoChannels.map((channel) => (
            <LatestChannelVideo
              channelName={channel.name}
              channelDescription={channel.description}
              channelLogoSrc={channelBranding[channel.id].logoSrc}
              channelAccentColor={channelBranding[channel.id].accentColor}
              channelDarkAccentColor={
                channelBranding[channel.id].darkAccentColor
              }
              channelCardBackground={channelBranding[channel.id].cardBackground}
              channelDarkCardBackground={
                channelBranding[channel.id].darkCardBackground
              }
              channelCardTint={channelBranding[channel.id].cardTint}
              channelDarkCardTint={channelBranding[channel.id].darkCardTint}
              channelLogoBackgroundColor={
                channelBranding[channel.id].logoBackgroundColor
              }
              channelDarkLogoBackgroundColor={
                channelBranding[channel.id].darkLogoBackgroundColor
              }
              channelLogoFit={channelBranding[channel.id].logoFit}
              channelLogoPaddingClass={
                channelBranding[channel.id].logoPaddingClass
              }
              video={latestYoutubeVideos[channel.id]}
            />
          ))
        }
      </section>

      <TopicCards />

      <nav
        class="animate-fade-in-up mx-auto mt-8 flex w-full max-w-xl flex-col gap-4 px-4 delay-500 sm:px-6"
        aria-label="Official social links"
      >
        {
          socialLinks.map((social) => (
            <SocialLinkButton
              label={social.label}
              href={social.url}
              id={social.id}
              style={{
                '--brand-color': social.color,
                '--brand-color-2': social.color2,
                '--brand-color-3': social.color3,
                '--brand-color-dark': social.darkColor ?? social.color,
                '--brand-color-dark-2': social.darkColor2 ?? social.color2,
                '--brand-color-dark-3': social.darkColor3 ?? social.color3,
              }}
            >
              <svg
                class="size-9"
                viewBox="0 0 24 24"
                aria-hidden="true"
                set:html={socialIconBodies[social.id]}
              />
            </SocialLinkButton>
          ))
        }
      </nav>

      <div
        class="animate-fade-in-up mx-auto mt-8 w-full max-w-xl px-4 delay-500 sm:px-6"
      >
        <section
          class="collaboration-cta rounded-xl px-5 py-6 text-left sm:px-6"
          aria-labelledby="collaboration-title"
        >
          <p
            class="text-primary text-xs font-bold tracking-[0.18em] uppercase"
          >
            For collaborations
          </p>
          <h2
            id="collaboration-title"
            class="text-foreground mt-2 text-2xl font-extrabold"
          >
            Sponsor, interview, or feature your story.
          </h2>
          <p class="text-muted-foreground mt-2 text-base leading-relaxed">
            Reach Arab communities across America through episodes, interviews,
            field visits, and social-first features.
          </p>
          {
            instagramLink && (
              <a
                href={instagramLink.url}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-primary text-primary-foreground hover:bg-primary/90 focus-visible:ring-ring/30 focus-visible:ring-offset-background mt-5 inline-flex min-h-12 items-center justify-center gap-2 rounded-full px-5 text-base font-bold transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
              >
                <Icon
                  name="simple-icons:instagram"
                  class="size-5"
                  aria-hidden="true"
                />
                DM on Instagram
              </a>
            )
          }
        </section>
      </div>

      <footer
        class="text-muted-foreground mt-auto w-full px-4 pt-12 pb-4 text-center text-sm"
      >
        <p class="mb-1">
          &copy; {currentYear}
          {pageTitle}. All rights reserved.
        </p>
        <p>
          Built with
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener"
            class="text-primary hover:text-primary/80 underline transition-colors"
          >
            Astro
          </a>
          &amp;
          <a
            href="https://tailwindcss.com"
            target="_blank"
            rel="noopener"
            class="text-primary hover:text-primary/80 underline transition-colors"
          >
            Tailwind CSS
          </a>.
        </p>
      </footer>
    </main>

    <script is:inline>
      ;(() => {
        const preferences = ['system', 'light', 'dark']
        const lightThemeColor = '#ffffff'
        const darkThemeColor = '#1c1917'
        const systemQuery = window.matchMedia('(prefers-color-scheme: dark)')
        const buttons = [...document.querySelectorAll('[data-theme-option]')]
        const hasThemeControls = buttons.length > 0

        const getStoredTheme = () => {
          if (!hasThemeControls) return null

          try {
            return localStorage.getItem('theme')
          } catch {
            return null
          }
        }

        const setStoredTheme = (theme) => {
          try {
            if (theme === 'system') localStorage.removeItem('theme')
            else localStorage.setItem('theme', theme)
          } catch {}
        }

        const getPreference = () => getStoredTheme() ?? 'system'

        const resolveTheme = (preference) =>
          preference === 'system'
            ? systemQuery.matches
              ? 'dark'
              : 'light'
            : preference

        const applyTheme = (preference = 'system') => {
          const theme = resolveTheme(preference)

          document.documentElement.classList.toggle('dark', theme === 'dark')
          document.documentElement.style.colorScheme = theme

          document
            .querySelectorAll('meta[name="theme-color"]')
            .forEach((meta) => {
              meta.content = theme === 'dark' ? darkThemeColor : lightThemeColor
              meta.media = ''
            })

          buttons.forEach((button) => {
            button.setAttribute(
              'aria-pressed',
              String(button.dataset.themeOption === preference),
            )
          })
        }

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const preference = button.dataset.themeOption
            if (!preferences.includes(preference)) return

            setStoredTheme(preference)
            applyTheme(preference)
          })
        })

        const handleSystemChange = () => {
          if (getPreference() === 'system') applyTheme('system')
        }

        systemQuery.addEventListener('change', handleSystemChange)
        applyTheme(getPreference())
      })()
    </script>

    <script is:inline>
      ;(() => {
        const shareButton = document.querySelector('[data-share-page]')
        if (!shareButton) return

        const defaultLabel =
          shareButton.getAttribute('aria-label') || 'Share Ya Hala with Haithum'
        const shareData = {
          title: shareButton.dataset.shareTitle,
          text: shareButton.dataset.shareText,
          url: shareButton.dataset.shareUrl,
        }
        const fallbackShareText = [shareData.title, shareData.text, shareData.url]
          .filter(Boolean)
          .join('\n')

        const restoreLabel = () => {
          window.setTimeout(() => {
            shareButton.setAttribute('aria-label', defaultLabel)
          }, 2200)
        }

        const copyLink = async () => {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(fallbackShareText)
            shareButton.setAttribute('aria-label', 'Share text copied')
            restoreLabel()
            return
          }

          window.location.href = shareData.url
        }

        shareButton.addEventListener('click', async () => {
          if (
            navigator.share &&
            (!navigator.canShare || navigator.canShare(shareData))
          ) {
            try {
              await navigator.share(shareData)
              return
            } catch (error) {
              if (error?.name === 'AbortError') return
            }
          }

          try {
            await copyLink()
          } catch {
            window.location.href = shareData.url
          }
        })
      })()
    </script>
  </body>
</html>
