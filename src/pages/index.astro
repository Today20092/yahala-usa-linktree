---
import '../styles.css'

import { Icon } from 'astro-icon/components'

import LatestChannelVideo from '../components/LatestChannelVideo.astro'
import Link from '../components/Link.astro'
import QrCodeButton from '../components/QrCodeButton.astro'
import ReachBadge from '../components/ReachBadge.astro'
import VideoBentoGrid from '../components/VideoBentoGrid.astro'
import heroCover from '../assets/yahala-hero-cover.png'
import latestYoutubeVideos from '../data/latest-youtube-videos.json'
import socialReach from '../data/social-reach.json'
import youtubeChannels from '../data/youtube-channels.json'

const pageTitle = 'Ya Hala with Haithum ياهلا مع هيثم'
const pageDescription =
  'Real stories, field interviews, and community highlights from Arabs building life, work, and impact across America.'
const siteName = 'Ya Hala with Haithum'
const profileName = 'Haithum'
const heroImageAlt = 'Ya Hala with Haithum ياهلا مع هيثم social cover'
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
const profileImageUrl = `${baseUrl}yahala-channel-logo.png`
const currentYear = new Date().getFullYear()
const canonicalUrl = new URL(baseUrl, Astro.site).toString()
const sitemapUrl = new URL(`${baseUrl}sitemap-index.xml`, Astro.site).toString()
const heroImagePath = heroCover.src
const heroImageUrl = new URL(`${baseUrl}og-image.png`, Astro.site).toString()

const latestVideoChannels = youtubeChannels.filter((channel) =>
  Boolean(latestYoutubeVideos[channel.id]),
)
const totalReach = socialReach.items.reduce((sum, item) => sum + item.value, 0)

const channelBranding = {
  yahala: {
    logoSrc: profileImageUrl,
    accentColor: '#ff0033',
    darkAccentColor: '#ff6b7f',
    cardBackground: '#fff7f7',
    darkCardBackground: '#251112',
    cardTint: '#ffe6e9',
    darkCardTint: '#3a171a',
    logoBackgroundColor: '#ffffff',
    darkLogoBackgroundColor: '#1f1f1f',
    logoFit: 'contain',
    logoPaddingClass: 'p-1.5',
  },
}

const socialLinks = [
  {
    id: 'youtube',
    url: 'https://www.youtube.com/channel/UC26OIuJ19EH6HF6uRJ-N_2A',
    icon: 'simple-icons:youtube',
    label: 'Ya Hala YouTube',
    color: '#ff0000',
    color2: '#ff5f5f',
    color3: '#ffffff',
    darkColor: '#ff3131',
    darkColor2: '#7a0000',
    darkColor3: '#1f0000',
  },
  {
    id: 'tiktok',
    url: 'https://www.tiktok.com/@yahala.usa?_t=zt-8yso6coegid&_r=1',
    icon: 'simple-icons:tiktok',
    label: 'Ya Hala TikTok',
    color: '#010101',
    color2: '#25f4ee',
    color3: '#fe2c55',
    darkColor: '#010101',
    darkColor2: '#25f4ee',
    darkColor3: '#fe2c55',
  },
  {
    id: 'instagram',
    url: 'https://instagram.com/yahala_usa?igshid=YmMyMTA2M2Y=',
    icon: 'simple-icons:instagram',
    label: 'Ya Hala Instagram',
    color: '#e4405f',
    color2: '#f77737',
    color3: '#833ab4',
    darkColor: '#e4405f',
    darkColor2: '#f77737',
    darkColor3: '#833ab4',
  },
  {
    id: 'facebook',
    url: 'https://www.facebook.com/YaHala.USA/',
    icon: 'simple-icons:facebook',
    label: 'Ya Hala Facebook',
    color: '#1877f2',
    color2: '#74a7ff',
    color3: '#0b5fcc',
    darkColor: '#74a7ff',
    darkColor2: '#1877f2',
    darkColor3: '#052f7f',
  },
]

const sameAsUrls = socialLinks.map((link) => link.url)

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${canonicalUrl}#profile-page`,
  url: canonicalUrl,
  name: pageTitle,
  description: pageDescription,
  image: heroImageUrl,
  inLanguage: 'en',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${canonicalUrl}#website`,
    url: canonicalUrl,
    name: siteName,
  },
  mainEntity: {
    '@type': 'Person',
    '@id': `${canonicalUrl}#person`,
    name: profileName,
    alternateName: siteName,
    description: pageDescription,
    image: profileImageUrl,
    url: canonicalUrl,
    sameAs: sameAsUrls,
  },
  significantLink: sameAsUrls,
}
---

<!doctype html>
<html lang="en" class="box-border">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />

    <link rel="icon" href={`${baseUrl}favicon.ico`} sizes="32x32" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={`${baseUrl}favicon-16x16.png`}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${baseUrl}favicon-32x32.png`}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${baseUrl}apple-touch-icon.png`}
    />
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <meta
      name="theme-color"
      content="oklch(0.987 0.008 82)"
      media="(prefers-color-scheme: light)"
      data-theme-color="light"
    />
    <meta
      name="theme-color"
      content="oklch(0.145 0.012 255)"
      media="(prefers-color-scheme: dark)"
      data-theme-color="dark"
    />

    <script is:inline>
      ;(() => {
        const lightThemeColor = 'oklch(0.987 0.008 82)'
        const darkThemeColor = 'oklch(0.145 0.012 255)'
        const storageKey = 'theme-preference'
        const systemQuery = window.matchMedia('(prefers-color-scheme: dark)')
        const savedPreference = (() => {
          try {
            return localStorage.getItem(storageKey)
          } catch {
            return null
          }
        })()
        const preference = ['light', 'dark', 'system'].includes(savedPreference)
          ? savedPreference
          : 'system'
        const theme =
          preference === 'system'
            ? systemQuery.matches
              ? 'dark'
              : 'light'
            : preference

        document.documentElement.dataset.theme = theme
        document.documentElement.dataset.themePreference = preference
        document.documentElement.style.colorScheme = theme

        document
          .querySelectorAll('meta[name="theme-color"]')
          .forEach((meta) => {
            meta.content = theme === 'dark' ? darkThemeColor : lightThemeColor
            meta.media = ''
          })
      })()
    </script>

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={heroImageUrl} />
    <meta property="og:image:alt" content={heroImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@yahala_usa" />
    <meta name="twitter:creator" content="@yahala_usa" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={heroImageUrl} />
    <meta name="twitter:image:alt" content={heroImageAlt} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href={sitemapUrl} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body
    class="linktree-page my-0 min-h-screen text-center text-lg subpixel-antialiased"
  >
    <main class="linktree-shell mx-auto flex w-full flex-col pb-6">
      <section
        class="linktree-hero animate-fade-in-up"
        aria-labelledby="profile-title"
      >
        <button
          type="button"
          class="linktree-hero__share"
          aria-label="Share Ya Hala with Haithum"
          data-share-page
          data-share-title={pageTitle}
          data-share-text={pageDescription}
          data-share-url={canonicalUrl}
        >
          <Icon
            name="heroicons:arrow-up-tray"
            class="h-5 w-5"
            aria-hidden="true"
          />
        </button>
        <img
          src={heroImagePath}
          alt={heroImageAlt}
          class="linktree-hero__image"
          decoding="async"
          loading="eager"
        />
        <div class="linktree-hero__fade" aria-hidden="true"></div>
      </section>

      <h1
        id="profile-title"
        class="font-display animate-fade-in-up text-on-surface mx-auto mt-5 mb-3 w-full max-w-[560px] px-4 text-3xl leading-tight delay-100 sm:px-6 sm:text-4xl"
      >
        <span class="block">Ya Hala with Haithum</span>
        <span class="mt-1 block text-[0.92em] sm:mt-2">ياهلا مع هيثم</span>
      </h1>
      <p
        class="animate-fade-in-up text-on-surface-variant mx-auto mb-4 w-full max-w-[560px] px-4 text-center text-base delay-200 sm:px-6"
      >
        Real stories, field interviews, and community highlights from Arabs
        building life, work, and impact across America.
      </p>

      <QrCodeButton />

      <VideoBentoGrid />

      <ReachBadge
        total={totalReach}
        updatedAt={socialReach.updatedAt}
        items={socialReach.items}
      />

      <section
        class="animate-fade-in-up mt-8 mb-5 flex flex-col gap-4 px-4 delay-400 sm:px-6"
        aria-label="Latest YouTube video"
      >
        {
          latestVideoChannels.map((channel) => (
            <LatestChannelVideo
              channelName={channel.name}
              channelDescription={channel.description}
              channelLogoSrc={channelBranding[channel.id].logoSrc}
              channelAccentColor={channelBranding[channel.id].accentColor}
              channelDarkAccentColor={
                channelBranding[channel.id].darkAccentColor
              }
              channelCardBackground={channelBranding[channel.id].cardBackground}
              channelDarkCardBackground={
                channelBranding[channel.id].darkCardBackground
              }
              channelCardTint={channelBranding[channel.id].cardTint}
              channelDarkCardTint={channelBranding[channel.id].darkCardTint}
              channelLogoBackgroundColor={
                channelBranding[channel.id].logoBackgroundColor
              }
              channelDarkLogoBackgroundColor={
                channelBranding[channel.id].darkLogoBackgroundColor
              }
              channelLogoFit={channelBranding[channel.id].logoFit}
              channelLogoPaddingClass={
                channelBranding[channel.id].logoPaddingClass
              }
              video={latestYoutubeVideos[channel.id]}
            />
          ))
        }
      </section>

      <nav
        class="animate-fade-in-up flex flex-col gap-4 px-4 delay-500 sm:px-6"
        aria-label="Official social links"
      >
        {
          socialLinks.map((social) => (
            <Link
              linktxt={social.label}
              bgcolor="brand-social-link"
              link={social.url}
              linkcolor=""
              id={social.id}
              border="border border-solid"
              style={`--brand-color: ${social.color}; --brand-color-2: ${
                social.color2
              }; --brand-color-3: ${social.color3}; --brand-color-dark: ${
                social.darkColor ?? social.color
              }; --brand-color-dark-2: ${
                social.darkColor2 ?? social.color2
              }; --brand-color-dark-3: ${social.darkColor3 ?? social.color3};`}
              extraClasses="text-lg font-bold"
            >
              <Icon
                slot="icon"
                name={social.icon}
                class="h-7 w-7"
                aria-hidden="true"
              />
            </Link>
          ))
        }
      </nav>

      <footer
        class="text-on-surface-variant mt-auto w-full px-4 pt-12 pb-4 text-center text-sm"
      >
        <p class="mb-1">
          &copy; {currentYear}
          {pageTitle}. All rights reserved.
        </p>
        <p>
          Built with
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener"
            class="text-primary hover:text-on-primary-container underline transition-colors"
          >
            Astro
          </a>
          &amp;
          <a
            href="https://tailwindcss.com"
            target="_blank"
            rel="noopener"
            class="text-primary hover:text-on-primary-container underline transition-colors"
          >
            Tailwind CSS
          </a>.
        </p>
      </footer>
    </main>

    <script is:inline>
      ;(() => {
        const storageKey = 'theme-preference'
        const preferences = ['system', 'light', 'dark']
        const lightThemeColor = 'oklch(0.987 0.008 82)'
        const darkThemeColor = 'oklch(0.145 0.012 255)'
        const systemQuery = window.matchMedia('(prefers-color-scheme: dark)')
        const buttons = [...document.querySelectorAll('[data-theme-option]')]

        const getPreference = () => {
          let savedPreference = null
          try {
            savedPreference = localStorage.getItem(storageKey)
          } catch {
            savedPreference = null
          }
          return preferences.includes(savedPreference)
            ? savedPreference
            : 'system'
        }

        const resolveTheme = (preference) =>
          preference === 'system'
            ? systemQuery.matches
              ? 'dark'
              : 'light'
            : preference

        const applyTheme = (preference) => {
          const theme = resolveTheme(preference)

          document.documentElement.dataset.theme = theme
          document.documentElement.dataset.themePreference = preference
          document.documentElement.style.colorScheme = theme

          document
            .querySelectorAll('meta[name="theme-color"]')
            .forEach((meta) => {
              meta.content = theme === 'dark' ? darkThemeColor : lightThemeColor
              meta.media = ''
            })

          buttons.forEach((button) => {
            button.setAttribute(
              'aria-pressed',
              String(button.dataset.themeOption === preference),
            )
          })
        }

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const preference = button.dataset.themeOption
            if (!preferences.includes(preference)) return

            try {
              localStorage.setItem(storageKey, preference)
            } catch {}
            applyTheme(preference)
          })
        })

        systemQuery.addEventListener('change', () => {
          if (getPreference() === 'system') {
            applyTheme('system')
          }
        })

        applyTheme(getPreference())
      })()
    </script>

    <script is:inline>
      ;(() => {
        const shareButton = document.querySelector('[data-share-page]')
        if (!shareButton) return

        const defaultLabel =
          shareButton.getAttribute('aria-label') || 'Share Ya Hala with Haithum'
        const shareData = {
          title: shareButton.dataset.shareTitle,
          text: shareButton.dataset.shareText,
          url: shareButton.dataset.shareUrl,
        }

        const restoreLabel = () => {
          window.setTimeout(() => {
            shareButton.setAttribute('aria-label', defaultLabel)
          }, 2200)
        }

        const copyLink = async () => {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(shareData.url)
            shareButton.setAttribute('aria-label', 'Link copied')
            restoreLabel()
            return
          }

          window.location.href = shareData.url
        }

        shareButton.addEventListener('click', async () => {
          if (navigator.share) {
            try {
              await navigator.share(shareData)
              return
            } catch (error) {
              if (error?.name === 'AbortError') return
            }
          }

          try {
            await copyLink()
          } catch {
            window.location.href = shareData.url
          }
        })
      })()
    </script>
  </body>
</html>
