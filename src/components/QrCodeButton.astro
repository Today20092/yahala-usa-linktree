---
import { Icon } from 'astro-icon/components'
import QRCode from 'qrcode'

const pageUrl = Astro.url.toString()
const displayUrl = (() => {
  try {
    const url = new URL(pageUrl)
    return `${url.host}${url.pathname}${url.search}${url.hash}`
  } catch {
    return pageUrl.replace(/^https?:\/\//, '')
  }
})()
const qrDataUrl = await QRCode.toDataURL(pageUrl, {
  color: {
    dark: '#020617',
    light: '#ffffff',
  },
  errorCorrectionLevel: 'M',
  margin: 2,
  width: 512,
})
---

<div class="mx-auto mt-5 flex justify-center lg:hidden">
  <button
    type="button"
    id="qr-open"
    class="text-foreground bg-accent elevation-2 hover:elevation-4 focus-visible:ring-ring/30 inline-flex items-center gap-2 rounded-xl px-4 py-3 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 focus-visible:ring-2 focus-visible:outline-none"
    aria-haspopup="dialog"
    aria-controls="qr-dialog"
  >
    <Icon name="heroicons:qr-code" class="size-5" aria-hidden="true" />
    <span>QR code</span>
  </button>
</div>

<aside
  class="qr-desktop-panel border-border/30 bg-accent/95 fixed right-7 bottom-7 z-40 hidden rounded-2xl border p-3 text-center shadow-lg backdrop-blur-sm lg:block"
  aria-label="View on mobile QR code"
>
  <p class="text-foreground mb-2 text-sm font-semibold">View on mobile</p>
  <div
    class="elevation-3 to-primary/10 rounded-[1.75rem] bg-gradient-to-br from-background via-background p-2 shadow-[0_18px_45px_rgb(15_23_42_/_0.16)]"
  >
    <img
      src={qrDataUrl}
      alt=""
      class="size-42 rounded-[1.35rem] bg-background p-1"
      aria-hidden="true"
    />
  </div>
</aside>

<div
  id="qr-dialog"
  class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-foreground/70 px-4 py-6 backdrop-blur-sm sm:py-8"
  role="dialog"
  aria-modal="true"
  aria-labelledby="qr-title"
>
  <div
    class="bg-background text-foreground elevation-4 max-h-[calc(100dvh-3rem)] w-full max-w-[22rem] overflow-y-auto rounded-2xl p-4 text-center sm:p-5"
  >
    <div class="mb-4 flex items-center justify-between gap-4 text-left">
      <h2 id="qr-title" class="text-lg font-bold">Share this page</h2>
      <button
        type="button"
        id="qr-close"
        class="hover:bg-accent focus-visible:ring-ring/30 grid size-10 place-items-center rounded-xl transition-colors focus-visible:ring-2 focus-visible:outline-none"
        aria-label="Close QR code"
      >
        <Icon name="heroicons:x-mark" class="size-6" aria-hidden="true" />
      </button>
    </div>
    <div
      class="to-primary/10 mx-auto grid aspect-square w-full max-w-64 place-items-center rounded-[2rem] bg-gradient-to-br from-background via-background p-3 shadow-[0_18px_55px_rgb(15_23_42_/_0.14)]"
    >
      <img
        src={qrDataUrl}
        alt=""
        class="h-full w-full max-w-56 rounded-[1.6rem] bg-background p-1"
        aria-hidden="true"
      />
    </div>
    <p
      class="text-muted-foreground mx-auto mt-4 max-w-full truncate text-[clamp(0.75rem,3.6vw,0.875rem)] font-medium"
      title={pageUrl}
    >
      {displayUrl}
    </p>
  </div>
</div>

<script>
  const dialog = document.getElementById('qr-dialog')
  const openButton = document.getElementById('qr-open')
  const closeButton = document.getElementById('qr-close')
  let previousFocus = null

  const openDialog = () => {
    if (!dialog) return

    previousFocus = document.activeElement
    dialog.classList.remove('hidden')
    dialog.classList.add('flex')
    document.documentElement.classList.add('overflow-hidden')
    closeButton?.focus()
  }

  const closeDialog = () => {
    if (!dialog) return

    dialog.classList.add('hidden')
    dialog.classList.remove('flex')
    document.documentElement.classList.remove('overflow-hidden')

    if (previousFocus instanceof HTMLElement) {
      previousFocus.focus()
    }
  }

  openButton?.addEventListener('click', openDialog)
  closeButton?.addEventListener('click', closeDialog)

  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) closeDialog()
  })

  document.addEventListener('keydown', (event) => {
    if (!dialog || dialog.classList.contains('hidden')) return
    if (event.key === 'Escape') closeDialog()
  })
</script>
