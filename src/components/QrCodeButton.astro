---
import { Icon } from 'astro-icon/components'
import QRCode from 'qrcode'

const pageUrl = Astro.url.toString()
const displayUrl = (() => {
  try {
    const url = new URL(pageUrl)
    return `${url.host}${url.pathname}${url.search}${url.hash}`
  } catch {
    return pageUrl.replace(/^https?:\/\//, '')
  }
})()
const qrDataUrl = await QRCode.toDataURL(pageUrl, {
  color: {
    dark: '#020617',
    light: '#ffffff',
  },
  errorCorrectionLevel: 'M',
  margin: 2,
  width: 512,
})
---

<div class="mx-auto mt-5 flex justify-center lg:hidden">
  <a
    href="#qr-dialog"
    data-qr-open
    class="text-foreground bg-accent elevation-2 hover:elevation-4 focus-visible:ring-ring/30 inline-flex items-center gap-2 rounded-full px-4 py-3 text-base font-semibold transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 focus-visible:ring-2 focus-visible:outline-none"
    aria-haspopup="dialog"
    aria-controls="qr-dialog"
  >
    <Icon name="heroicons:qr-code" class="size-5" aria-hidden="true" />
    <span>QR code</span>
  </a>
</div>

<a
  href="#qr-dialog"
  data-qr-open
  class="qr-desktop-panel border-border/30 bg-accent/95 elevation-3 focus-visible:ring-ring/30 fixed right-7 bottom-7 z-40 hidden rounded-xl border p-3 text-center backdrop-blur-sm focus-visible:ring-2 focus-visible:outline-none lg:block"
  aria-label="Open view on mobile QR code"
  aria-haspopup="dialog"
  aria-controls="qr-dialog"
>
  <p class="text-foreground mb-2 text-sm font-semibold">View on mobile</p>
  <div
    class="elevation-3 to-primary/10 from-background via-background rounded-xl bg-gradient-to-br p-2"
  >
    <img
      src={qrDataUrl}
      alt=""
      width="168"
      height="168"
      class="bg-background size-42 rounded-xl p-1"
      aria-hidden="true"
    />
  </div>
</a>

<div
  id="qr-dialog"
  class="bg-foreground/70 fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto px-4 py-6 backdrop-blur-sm target:flex sm:py-8"
  role="dialog"
  aria-modal="true"
  aria-labelledby="qr-title"
>
  <div
    class="bg-background text-foreground elevation-4 max-h-[calc(100dvh-3rem)] w-full max-w-[22rem] overflow-y-auto rounded-xl p-4 text-center sm:p-5"
  >
    <div class="mb-4 flex items-center justify-between gap-4 text-left">
      <h2 id="qr-title" class="text-lg font-bold">Share this page</h2>
      <a
        href="#"
        id="qr-close"
        class="hover:bg-accent focus-visible:ring-ring/30 grid size-10 place-items-center rounded-full transition-colors focus-visible:ring-2 focus-visible:outline-none"
        aria-label="Close QR code"
      >
        <Icon name="heroicons:x-mark" class="size-6" aria-hidden="true" />
      </a>
    </div>
    <div
      class="to-primary/10 from-background via-background elevation-3 mx-auto grid aspect-square w-full max-w-64 place-items-center rounded-xl bg-gradient-to-br p-3"
    >
      <img
        src={qrDataUrl}
        alt=""
        width="224"
        height="224"
        class="bg-background h-full w-full max-w-56 rounded-xl p-1"
        aria-hidden="true"
      />
    </div>
    <a
      href={pageUrl}
      data-qr-destination
      class="text-muted-foreground hover:text-foreground focus-visible:ring-ring/30 mx-auto mt-4 block max-w-full text-[clamp(0.75rem,3.6vw,0.875rem)] font-medium break-all underline-offset-4 hover:underline focus-visible:ring-2 focus-visible:outline-none"
      title={pageUrl}
    >
      {displayUrl}
    </a>
  </div>
</div>

<script>
  const dialog = document.getElementById('qr-dialog')
  const openButtons = document.querySelectorAll('[data-qr-open]')
  const closeButton = document.getElementById('qr-close')
  let previousFocus = null

  const openDialog = (trigger) => {
    if (!dialog) return

    previousFocus = trigger ?? document.activeElement
    dialog.classList.remove('hidden')
    dialog.classList.add('flex')
    document.documentElement.classList.add('overflow-hidden')
    closeButton?.focus()
  }

  const closeDialog = () => {
    if (!dialog) return

    if (dialog.matches(':target')) {
      history.replaceState(null, '', `${location.pathname}${location.search}`)
    }
    dialog.classList.add('hidden')
    dialog.classList.remove('flex')
    document.documentElement.classList.remove('overflow-hidden')

    if (previousFocus instanceof HTMLElement) {
      previousFocus.focus()
    }
  }

  openButtons.forEach((button) => {
    button.addEventListener('click', (event) => {
      event.preventDefault()
      openDialog(button)
    })
  })
  closeButton?.addEventListener('click', (event) => {
    event.preventDefault()
    closeDialog()
  })

  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) closeDialog()
  })

  document.addEventListener('keydown', (event) => {
    if (
      !dialog ||
      (dialog.classList.contains('hidden') && !dialog.matches(':target'))
    )
      return
    if (event.key === 'Escape') closeDialog()
  })

  if (dialog?.matches(':target')) openDialog()
</script>
