---
import { Icon } from 'astro-icon/components'
---

<div class="mx-auto mt-5 flex justify-center lg:hidden">
  <button
    type="button"
    id="qr-open"
    class="text-on-surface bg-surface-container-high elevation-2 hover:elevation-4 focus-visible:ring-primary/70 inline-flex items-center gap-2 rounded-xl px-4 py-3 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 focus-visible:ring-2 focus-visible:outline-none"
    aria-haspopup="dialog"
    aria-controls="qr-dialog"
  >
    <Icon name="heroicons:qr-code" class="h-5 w-5" aria-hidden="true" />
    <span>QR code</span>
  </button>
</div>

<aside
  class="qr-desktop-panel border-outline/30 bg-surface-container-high/95 fixed right-7 bottom-7 z-40 hidden rounded-2xl border p-3 text-center shadow-lg backdrop-blur-sm lg:block"
  aria-label="View on mobile QR code"
>
  <p class="text-on-surface mb-2 text-sm font-semibold">View on mobile</p>
  <div
    class="elevation-3 rounded-[1.75rem] bg-gradient-to-br from-white via-white to-primary/10 p-2 shadow-[0_18px_45px_rgb(15_23_42_/_0.16)]"
  >
    <canvas
      id="qr-canvas-desktop"
      width="168"
      height="168"
      class="size-42 rounded-[1.35rem] bg-white p-1"
      aria-hidden="true"
    >
    </canvas>
  </div>
</aside>

<div
  id="qr-dialog"
  class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-black/70 px-4 py-6 backdrop-blur-sm sm:py-8"
  role="dialog"
  aria-modal="true"
  aria-labelledby="qr-title"
>
  <div
    class="bg-surface text-on-surface elevation-4 max-h-[calc(100dvh-3rem)] w-full max-w-[22rem] overflow-y-auto rounded-2xl p-4 text-center sm:p-5"
  >
    <div class="mb-4 flex items-center justify-between gap-4">
      <h2 id="qr-title" class="text-lg font-bold">Share this page</h2>
      <button
        type="button"
        id="qr-close"
        class="hover:bg-surface-container-high focus-visible:ring-primary/70 grid h-10 w-10 place-items-center rounded-xl transition-colors focus-visible:ring-2 focus-visible:outline-none"
        aria-label="Close QR code"
      >
        <Icon name="heroicons:x-mark" class="h-6 w-6" aria-hidden="true" />
      </button>
    </div>
    <div
      class="mx-auto grid aspect-square w-full max-w-64 place-items-center rounded-[2rem] bg-gradient-to-br from-white via-white to-primary/10 p-3 shadow-[0_18px_55px_rgb(15_23_42_/_0.14)]"
    >
      <canvas
        id="qr-canvas"
        width="224"
        height="224"
        class="h-full w-full max-w-56 rounded-[1.6rem] bg-white p-1"
        aria-hidden="true"
      >
      </canvas>
    </div>
    <p
      id="qr-url"
      class="text-on-surface-variant mx-auto mt-4 max-w-full overflow-hidden text-[clamp(0.75rem,3.6vw,0.875rem)] font-medium text-ellipsis whitespace-nowrap"
    >
    </p>
  </div>
</div>

<script>
  import QRCode from 'qrcode'

  const dialog = document.getElementById('qr-dialog')
  const openButton = document.getElementById('qr-open')
  const closeButton = document.getElementById('qr-close')
  const canvas = document.getElementById('qr-canvas')
  const desktopCanvas = document.getElementById('qr-canvas-desktop')
  const urlText = document.getElementById('qr-url')
  let previousFocus = null

  const focusableSelector =
    'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'

  const roundedRect = (context, x, y, width, height, radius) => {
    const safeRadius = Math.min(radius, width / 2, height / 2)

    context.beginPath()
    context.moveTo(x + safeRadius, y)
    context.lineTo(x + width - safeRadius, y)
    context.quadraticCurveTo(x + width, y, x + width, y + safeRadius)
    context.lineTo(x + width, y + height - safeRadius)
    context.quadraticCurveTo(x + width, y + height, x + width - safeRadius, y + height)
    context.lineTo(x + safeRadius, y + height)
    context.quadraticCurveTo(x, y + height, x, y + height - safeRadius)
    context.lineTo(x, y + safeRadius)
    context.quadraticCurveTo(x, y, x + safeRadius, y)
    context.closePath()
    context.fill()
  }

  const isFinderCell = (row, column, moduleCount) => {
    const inTop = row < 7
    const inLeft = column < 7
    const inRight = column >= moduleCount - 7
    const inBottom = row >= moduleCount - 7

    return (inTop && inLeft) || (inTop && inRight) || (inBottom && inLeft)
  }

  const drawFinderEye = (context, x, y, moduleSize) => {
    roundedRect(context, x, y, moduleSize * 7, moduleSize * 7, moduleSize * 1.65)

    context.fillStyle = '#ffffff'
    roundedRect(
      context,
      x + moduleSize,
      y + moduleSize,
      moduleSize * 5,
      moduleSize * 5,
      moduleSize * 1.15
    )

    context.fillStyle = '#020617'
    roundedRect(
      context,
      x + moduleSize * 2,
      y + moduleSize * 2,
      moduleSize * 3,
      moduleSize * 3,
      moduleSize * 0.72
    )
  }

  const renderQrCode = (target, currentUrl, width) => {
    if (!(target instanceof HTMLCanvasElement)) return

    const qr = QRCode.create(currentUrl, {
      errorCorrectionLevel: 'L',
    })
    const context = target.getContext('2d')
    if (!context) return

    const margin = 2
    const moduleCount = qr.modules.size
    const moduleSize = width / (moduleCount + margin * 2)
    const offset = margin * moduleSize

    target.width = width
    target.height = width
    context.clearRect(0, 0, width, width)
    context.fillStyle = '#ffffff'
    roundedRect(context, 0, 0, width, width, width * 0.09)

    context.fillStyle = '#020617'

    for (let row = 0; row < moduleCount; row += 1) {
      for (let column = 0; column < moduleCount; column += 1) {
        if (
          !qr.modules.data[row * moduleCount + column] ||
          isFinderCell(row, column, moduleCount)
        ) {
          continue
        }

        const x = offset + column * moduleSize
        const y = offset + row * moduleSize

        context.fillRect(x, y, moduleSize, moduleSize)
      }
    }

    drawFinderEye(context, offset, offset, moduleSize)
    drawFinderEye(context, offset + (moduleCount - 7) * moduleSize, offset, moduleSize)
    drawFinderEye(context, offset, offset + (moduleCount - 7) * moduleSize, moduleSize)
  }

  const currentUrl = window.location.href
  const displayUrl = (() => {
    try {
      const url = new URL(currentUrl)
      return `${url.host}${url.pathname}${url.search}${url.hash}`
    } catch {
      return currentUrl.replace(/^https?:\/\//, '')
    }
  })()
  void renderQrCode(desktopCanvas, currentUrl, 168)

  const openDialog = async () => {
    if (!dialog || !canvas || !urlText) return

    previousFocus = document.activeElement
    urlText.textContent = displayUrl
    urlText.title = currentUrl

    await renderQrCode(canvas, currentUrl, 224)

    dialog.classList.remove('hidden')
    dialog.classList.add('flex')
    document.documentElement.classList.add('overflow-hidden')
    closeButton?.focus()
  }

  const closeDialog = () => {
    if (!dialog) return

    dialog.classList.add('hidden')
    dialog.classList.remove('flex')
    document.documentElement.classList.remove('overflow-hidden')

    if (previousFocus instanceof HTMLElement) {
      previousFocus.focus()
    }
  }

  openButton?.addEventListener('click', () => {
    void openDialog()
  })

  closeButton?.addEventListener('click', closeDialog)

  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) closeDialog()
  })

  document.addEventListener('keydown', (event) => {
    if (!dialog || dialog.classList.contains('hidden')) return

    if (event.key === 'Escape') {
      closeDialog()
      return
    }

    if (event.key !== 'Tab') return

    const focusable = [...dialog.querySelectorAll(focusableSelector)].filter(
      (element) => element instanceof HTMLElement,
    )

    if (focusable.length === 0) return

    const first = focusable[0]
    const last = focusable[focusable.length - 1]

    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault()
      last.focus()
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault()
      first.focus()
    }
  })
</script>
