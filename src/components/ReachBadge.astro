---
import { Icon } from 'astro-icon/components'

type ReachItem = {
  platform: string
  metric: string
  value: number
}

type ReachBadgeProps = {
  total: number
  updatedAt: string
  items: ReachItem[]
}

const { total, updatedAt, items } = Astro.props as ReachBadgeProps

const formatNumber = (value: number) => {
  const formatter = new Intl.NumberFormat('en-US', {
    maximumFractionDigits: value >= 1000000 ? 1 : 0,
  })

  if (value >= 1000000) return `${formatter.format(value / 1000000)}M`
  if (value >= 1000) return `${formatter.format(value / 1000)}K`
  return formatter.format(value)
}

const updatedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(new Date(updatedAt))

const platformTotals = Object.values(
  items.reduce<Record<string, { platform: string; total: number }>>(
    (totals, item) => {
      totals[item.platform] ??= { platform: item.platform, total: 0 }
      totals[item.platform].total += item.value
      return totals
    },
    {},
  ),
)
---

<aside
  data-reach-card
  class="animate-fade-in-up mx-auto mt-6 w-full max-w-[592px] px-4 delay-300 sm:max-w-[608px] sm:px-6"
  aria-label="Total people reached"
>
  <div
    class="text-on-surface overflow-hidden rounded-xl border border-[oklch(0.86_0.032_88)] bg-[linear-gradient(135deg,oklch(0.99_0.016_86),oklch(0.965_0.024_145)_48%,oklch(0.975_0.026_32))] shadow-[0_20px_45px_oklch(0.35_0.045_70_/_0.16)] dark:border-[oklch(0.34_0.028_250)] dark:bg-[linear-gradient(135deg,oklch(0.18_0.018_248),oklch(0.205_0.026_165)_48%,oklch(0.19_0.028_35))] dark:shadow-[0_24px_52px_oklch(0_0_0_/_0.34)]"
  >
    <div class="px-5 py-5 sm:px-6">
      <div class="mb-4 flex items-center justify-center gap-2">
        <span
          class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-[oklch(0.91_0.08_145)] text-[oklch(0.31_0.085_150)] ring-1 ring-[oklch(0.79_0.07_145)] dark:bg-[oklch(0.3_0.07_150)] dark:text-[oklch(0.87_0.09_145)] dark:ring-[oklch(0.42_0.075_150)]"
          aria-hidden="true"
        >
          <Icon name="heroicons:globe-americas" class="h-5 w-5" />
        </span>
        <span class="text-left">
          <span
            class="block text-sm font-semibold text-[oklch(0.24_0.018_255)] dark:text-[oklch(0.94_0.018_82)]"
          >
            People reached
          </span>
          <span
            class="block text-xs text-[oklch(0.48_0.03_255)] dark:text-[oklch(0.76_0.03_82)]"
          >
            Updated {updatedDate}
          </span>
        </span>
      </div>

      <p
        class="text-center text-5xl leading-none font-black tracking-normal text-[oklch(0.16_0.02_255)] tabular-nums sm:text-6xl dark:text-[oklch(0.98_0.01_82)]"
      >
        <span data-count-value={total}>{formatNumber(total)}</span><span
          class="text-[oklch(0.38_0.11_145)] dark:text-[oklch(0.75_0.12_145)]"
        >
          +
        </span>
      </p>
      <p
        class="mx-auto mt-3 max-w-sm text-center text-sm leading-snug text-[oklch(0.38_0.028_255)] dark:text-[oklch(0.8_0.028_82)]"
      >
        Across YouTube, TikTok, Instagram, and Facebook
      </p>
    </div>

    <dl
      class="grid grid-cols-2 border-t border-[oklch(0.86_0.032_88)] bg-[oklch(0.97_0.018_82_/_0.78)] sm:grid-cols-4 dark:border-[oklch(0.34_0.028_250)] dark:bg-[oklch(0.15_0.014_250_/_0.58)]"
    >
      {
        platformTotals.map((item) => (
          <div class="border-[oklch(0.86_0.032_88)] px-3 py-3 text-center not-last:border-r dark:border-[oklch(0.34_0.028_250)]">
            <dt class="truncate text-xs font-semibold text-[oklch(0.43_0.032_255)] dark:text-[oklch(0.77_0.03_82)]">
              {item.platform}
            </dt>
            <dd
              class="mt-1 text-base font-bold text-[oklch(0.17_0.018_255)] tabular-nums dark:text-[oklch(0.96_0.012_82)]"
              data-count-value={item.total}
            >
              {formatNumber(item.total)}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</aside>

<script>
  const reachCard = document.querySelector('[data-reach-card]')
  const animatedNumbers = reachCard?.querySelectorAll('[data-count-value]')

  const formatAnimatedNumber = (value, target) => {
    const formatter = new Intl.NumberFormat('en-US', {
      maximumFractionDigits: target >= 1000000 ? 1 : 0,
      minimumFractionDigits: target >= 1000000 ? 1 : 0,
    })

    if (target >= 1000000) return `${formatter.format(value / 1000000)}M`
    if (target >= 1000) return `${formatter.format(value / 1000)}K`
    return formatter.format(value)
  }

  const animateNumber = (element) => {
    if (!(element instanceof HTMLElement) || element.dataset.counted) return

    const target = Number(element.dataset.countValue)
    if (!Number.isFinite(target)) return

    element.dataset.counted = 'true'

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      element.textContent = formatAnimatedNumber(target, target)
      return
    }

    const duration = 1400
    const startedAt = performance.now()

    const tick = (now) => {
      const progress = Math.min((now - startedAt) / duration, 1)
      const eased = 1 - Math.pow(1 - progress, 3)
      element.textContent = formatAnimatedNumber(target * eased, target)

      if (progress < 1) {
        requestAnimationFrame(tick)
        return
      }

      element.textContent = formatAnimatedNumber(target, target)
    }

    element.textContent = formatAnimatedNumber(0, target)
    requestAnimationFrame(tick)
  }

  if ('IntersectionObserver' in window && reachCard && animatedNumbers) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return

        animatedNumbers.forEach(animateNumber)
        observer.disconnect()
      },
      { threshold: 0.35 },
    )

    observer.observe(reachCard)
  } else {
    animatedNumbers?.forEach(animateNumber)
  }
</script>
