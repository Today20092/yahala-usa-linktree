---
import { Icon } from 'astro-icon/components'

import { CountingNumber } from './animate-ui/primitives/texts/counting-number'

type ReachItem = {
  platform: string
  metric: string
  value: number
}

type ReachBadgeProps = {
  total: number
  updatedAt: string
  items: ReachItem[]
}

const { total, updatedAt, items } = Astro.props as ReachBadgeProps

const platformIcons: Record<string, string> = {
  YouTube: 'simple-icons:youtube',
  TikTok: 'simple-icons:tiktok',
  Instagram: 'simple-icons:instagram',
  Facebook: 'simple-icons:facebook',
}

const platformColors: Record<
  string,
  {
    accent: string
    darkAccent: string
  }
> = {
  YouTube: {
    accent: 'var(--social-youtube)',
    darkAccent: 'var(--social-youtube-dark)',
  },
  TikTok: {
    accent: 'var(--social-tiktok)',
    darkAccent: 'var(--social-tiktok-dark-2)',
  },
  Instagram: {
    accent: 'var(--social-instagram)',
    darkAccent: 'var(--social-instagram-dark)',
  },
  Facebook: {
    accent: 'var(--social-facebook)',
    darkAccent: 'var(--social-facebook-dark)',
  },
}

const updatedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
}).format(new Date(updatedAt))

const largestPlatformTotal = Math.max(...items.map((item) => item.value), 0)

const platformTotals = Object.values(
  items.reduce<Record<string, { platform: string; total: number }>>(
    (totals, item) => {
      totals[item.platform] ??= { platform: item.platform, total: 0 }
      totals[item.platform].total += item.value
      return totals
    },
    {},
  ),
).map((item) => {
  const colors = platformColors[item.platform] ?? {
    accent: 'var(--primary)',
    darkAccent: 'var(--primary)',
  }

  return {
    ...item,
    icon: platformIcons[item.platform] ?? 'heroicons:chart-bar',
    share:
      largestPlatformTotal > 0 ? (item.total / largestPlatformTotal) * 100 : 0,
    ...colors,
  }
})
---

<aside
  data-reach-card
  data-reach-chart
  class="ui-section-block animate-fade-in-up mx-auto w-full max-w-xl px-4 delay-300 sm:px-6"
  aria-label="Total people reached"
>
  <div class="reach-summary">
    <header class="reach-summary__headline">
      <div class="reach-summary__heading-row">
        <h2 class="ui-section-title">People reached</h2>
        <p class="ui-meta">Updated {updatedDate}</p>
      </div>

      <p class="reach-summary__total">
        <CountingNumber
          client:visible
          number={total}
          locale="en-US"
          inView
          inViewOnce
          startEvent="reach-chart:enhance"
        /><span class="text-primary">+</span>
      </p>
      <p class="ui-body reach-summary__description">
        Total audience across YouTube, TikTok, Instagram, and Facebook.
      </p>
    </header>

    <dl class="reach-summary__stats">
      {
        platformTotals.map((item) => (
          <div
            style={`--platform-accent: ${item.accent}; --platform-accent-dark: ${item.darkAccent}; --platform-share: ${item.share}%;`}
            class="reach-summary__stat [--platform-active-accent:var(--platform-accent)] dark:[--platform-active-accent:var(--platform-accent-dark)]"
          >
            <div class="reach-summary__stat-row">
              <dt class="ui-meta flex min-w-0 items-center gap-2 truncate">
                <Icon
                  name={item.icon}
                  class="size-3.5 shrink-0 text-[var(--platform-active-accent)]"
                  aria-hidden="true"
                />
                <span class="truncate">{item.platform}</span>
              </dt>
              <dd class="text-foreground text-sm font-semibold tabular-nums sm:text-base">
                <CountingNumber
                  client:visible
                  number={item.total}
                  locale="en-US"
                  inView
                  inViewOnce
                  delay={100}
                  startEvent="reach-chart:enhance"
                />
              </dd>
            </div>
            <div class="reach-summary__bar" aria-hidden="true">
              <span />
            </div>
          </div>
        ))
      }
    </dl>
  </div>
</aside>

<style>
  [data-reach-chart] .reach-summary__stats {
    display: grid;
    gap: var(--space-md);
    margin: 0;
  }

  [data-reach-chart] .reach-summary__stat {
    min-width: 0;
    padding: 0;
    background: transparent;
  }

  [data-reach-chart] .reach-summary__bar {
    height: var(--space-3xs);
    margin-block-start: var(--space-2xs);
    overflow: hidden;
    border-radius: var(--radius-pill);
    background: var(--color-rule);
  }

  [data-reach-chart] .reach-summary__bar > span {
    display: block;
    width: var(--platform-share);
    height: 100%;
    transform-origin: left;
    border-radius: inherit;
    background: var(--platform-active-accent);
  }
</style>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document
      .querySelectorAll('[data-reach-chart]')
      .forEach(async (chart) => {
        const islands = [...chart.querySelectorAll('astro-island')]

        await Promise.all(
          islands.map(
            (island) =>
              new Promise<void>((resolve) => {
                if (!island.hasAttribute('ssr')) return resolve()
                island.addEventListener('astro:hydrate', () => resolve(), {
                  once: true,
                })
              }),
          ),
        )

        chart.setAttribute('data-reach-enhanced', '')
        window.dispatchEvent(new Event('reach-chart:enhance'))
      })
  }
</script>
