---
import { Icon } from 'astro-icon/components'

type ReachItem = {
  platform: string
  metric: string
  value: number
}

type ReachBadgeProps = {
  total: number
  updatedAt: string
  items: ReachItem[]
}

const { total, updatedAt, items } = Astro.props as ReachBadgeProps

const platformIcons: Record<string, string> = {
  YouTube: 'simple-icons:youtube',
  TikTok: 'simple-icons:tiktok',
  Instagram: 'simple-icons:instagram',
  Facebook: 'simple-icons:facebook',
}

const platformColors: Record<
  string,
  {
    accent: string
    darkAccent: string
    tint: string
    darkTint: string
  }
> = {
  YouTube: {
    accent: '#ff0000',
    darkAccent: '#ff5f5f',
    tint: '#fff1f1',
    darkTint: '#2a1010',
  },
  TikTok: {
    accent: '#010101',
    darkAccent: '#25f4ee',
    tint: '#f3f4f6',
    darkTint: '#0b1f20',
  },
  Instagram: {
    accent: '#e4405f',
    darkAccent: '#ff7a9a',
    tint: '#fff1f6',
    darkTint: '#2a101b',
  },
  Facebook: {
    accent: '#1877f2',
    darkAccent: '#74a7ff',
    tint: '#eef5ff',
    darkTint: '#0b1a2e',
  },
}

const formatNumber = (value: number) => {
  const formatter = new Intl.NumberFormat('en-US', {
    maximumFractionDigits: value >= 1000000 ? 1 : 0,
  })

  if (value >= 1000000) return `${formatter.format(value / 1000000)}M`
  if (value >= 1000) return `${formatter.format(value / 1000)}K`
  return formatter.format(value)
}

const updatedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(new Date(updatedAt))

const platformTotals = Object.values(
  items.reduce<Record<string, { platform: string; total: number }>>(
    (totals, item) => {
      totals[item.platform] ??= { platform: item.platform, total: 0 }
      totals[item.platform].total += item.value
      return totals
    },
    {},
  ),
).map((item) => {
  const colors = platformColors[item.platform] ?? {
    accent: 'var(--color-primary)',
    darkAccent: 'var(--color-primary)',
    tint: 'var(--color-card)',
    darkTint: 'var(--color-card)',
  }

  return {
    ...item,
    icon: platformIcons[item.platform] ?? 'heroicons:chart-bar',
    ...colors,
  }
})
---

<aside
  data-reach-card
  class="animate-fade-in-up mx-auto mt-6 w-full max-w-xl px-4 delay-300 sm:px-6"
  aria-label="Total people reached"
>
  <div
    class="text-on-surface overflow-hidden rounded-xl border border-border bg-card shadow-[0_20px_45px_color-mix(in_srgb,var(--color-shadow)_12%,transparent)] dark:border-outline dark:bg-surface-container dark:shadow-[0_24px_52px_oklch(0_0_0_/_0.34)]"
  >
    <div class="px-5 py-5 sm:px-6">
      <div class="mb-4 flex items-center justify-center gap-2">
        <span
          class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-primary-container text-primary ring-1 ring-primary/25 dark:bg-primary-container dark:text-primary"
          aria-hidden="true"
        >
          <Icon name="heroicons:globe-americas" class="h-5 w-5" />
        </span>
        <span class="text-left">
          <span class="block text-sm font-semibold text-on-surface">
            People reached
          </span>
          <span class="block text-xs text-on-surface-variant">
            Updated {updatedDate}
          </span>
        </span>
      </div>

      <p
        class="text-on-surface text-center text-5xl leading-none font-black tracking-normal tabular-nums sm:text-6xl"
      >
        <span data-count-value={total} data-growing-reach>
          {formatNumber(total)}
        </span><span class="text-primary">
          +
        </span>
      </p>
      <p
        class="text-on-surface-variant mx-auto mt-3 max-w-sm text-center text-sm leading-snug"
      >
        Across YouTube, TikTok, Instagram, and Facebook
      </p>
      <p
        class="text-on-surface-variant mt-2 text-center text-xs font-bold tracking-normal tabular-nums dark:text-on-surface"
        aria-live="off"
      >
        <span data-growing-reach-detail>
          {new Intl.NumberFormat('en-US').format(total)}
        </span> and growing
      </p>
    </div>

    <dl
      class="grid grid-cols-2 gap-px border-t border-border bg-border p-px dark:bg-[color:var(--color-neutral-800)] sm:grid-cols-4"
    >
      {
        platformTotals.map((item) => (
          <div
            style={`--platform-accent: ${item.accent}; --platform-accent-dark: ${item.darkAccent}; --platform-tint: ${item.tint}; --platform-tint-dark: ${item.darkTint};`}
            class="bg-[linear-gradient(135deg,color-mix(in_srgb,var(--platform-active-tint)_34%,var(--color-card))_0%,var(--color-card)_76%)] px-3 py-3 text-center ring-1 ring-inset ring-[color-mix(in_srgb,var(--platform-active-accent)_18%,transparent)] [--platform-active-accent:var(--platform-accent)] [--platform-active-tint:var(--platform-tint)] dark:bg-[linear-gradient(135deg,color-mix(in_srgb,var(--platform-active-tint)_42%,var(--color-card))_0%,var(--color-card)_78%)] dark:ring-[color-mix(in_srgb,var(--platform-active-accent)_12%,var(--color-neutral-800))] dark:[--platform-active-accent:var(--platform-accent-dark)] dark:[--platform-active-tint:var(--platform-tint-dark)]"
          >
            <dt class="flex min-w-0 items-center justify-center gap-1.5 truncate text-xs font-semibold text-on-surface-variant">
              <Icon
                name={item.icon}
                class="h-3.5 w-3.5 shrink-0 text-[var(--platform-active-accent)]"
                aria-hidden="true"
              />
              <span class="truncate">{item.platform}</span>
            </dt>
            <dd
              class="text-on-surface mt-1 text-base font-bold tabular-nums"
              data-count-value={item.total}
            >
              {formatNumber(item.total)}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</aside>

<script>
  const reachCard = document.querySelector('[data-reach-card]')
  const animatedNumbers = reachCard?.querySelectorAll('[data-count-value]')
  const growingReachNumber = reachCard?.querySelector('[data-growing-reach]')
  const growingReachDetail = reachCard?.querySelector(
    '[data-growing-reach-detail]',
  )
  const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)')

  const formatAnimatedNumber = (value, target) => {
    const formatter = new Intl.NumberFormat('en-US', {
      maximumFractionDigits: target >= 1000000 ? 1 : 0,
      minimumFractionDigits: target >= 1000000 ? 1 : 0,
    })

    if (target >= 1000000) return `${formatter.format(value / 1000000)}M`
    if (target >= 1000) return `${formatter.format(value / 1000)}K`
    return formatter.format(value)
  }

  const growReachNumber = (element, baseValue) => {
    if (!(element instanceof HTMLElement) || reduceMotionQuery.matches) return

    const visibleStep = baseValue >= 1000000 ? 100000 : 1000
    const incrementPerSecond = visibleStep / 12
    const maxVisibleGrowth = visibleStep * 12
    const fullFormatter = new Intl.NumberFormat('en-US')
    const startedAt = performance.now()

    const tick = (now) => {
      const elapsedSeconds = (now - startedAt) / 1000
      const addedReach = (elapsedSeconds * incrementPerSecond) % maxVisibleGrowth
      const displayValue = baseValue + addedReach

      element.textContent = formatAnimatedNumber(displayValue, baseValue)
      if (growingReachDetail instanceof HTMLElement) {
        growingReachDetail.textContent = fullFormatter.format(
          Math.floor(displayValue),
        )
      }
      requestAnimationFrame(tick)
    }

    requestAnimationFrame(tick)
  }

  const animateNumber = (element) => {
    if (!(element instanceof HTMLElement) || element.dataset.counted) return

    const target = Number(element.dataset.countValue)
    if (!Number.isFinite(target)) return

    element.dataset.counted = 'true'

    if (reduceMotionQuery.matches) {
      element.textContent = formatAnimatedNumber(target, target)
      return
    }

    const duration = 1400
    const startedAt = performance.now()

    const tick = (now) => {
      const progress = Math.min((now - startedAt) / duration, 1)
      const eased = 1 - Math.pow(1 - progress, 3)
      element.textContent = formatAnimatedNumber(target * eased, target)

      if (progress < 1) {
        requestAnimationFrame(tick)
        return
      }

      element.textContent = formatAnimatedNumber(target, target)
      if (element === growingReachNumber) growReachNumber(element, target)
    }

    element.textContent = formatAnimatedNumber(0, target)
    requestAnimationFrame(tick)
  }

  if ('IntersectionObserver' in window && reachCard && animatedNumbers) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return

        animatedNumbers.forEach(animateNumber)
        observer.disconnect()
      },
      { threshold: 0.35 },
    )

    observer.observe(reachCard)
  } else {
    animatedNumbers?.forEach(animateNumber)
  }
</script>
