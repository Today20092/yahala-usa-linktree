---
import { Icon } from 'astro-icon/components'

const topics = [
  {
    title: 'Arab businesses & brands',
    description: 'Founders, shops, products, and the work behind local success.',
    icon: 'heroicons:building-storefront',
  },
  {
    title: 'Halal food & markets',
    description: 'Restaurants, food trucks, coffee, groceries, and halal spots.',
    icon: 'heroicons:shopping-bag',
  },
  {
    title: 'Immigrant success stories',
    description: 'Journeys, first wins, hard lessons, and new lives in America.',
    icon: 'heroicons:map',
  },
  {
    title: 'Arab America neighborhoods',
    description:
      'Cities, communities, and Arab American life from coast to coast.',
    icon: 'heroicons:globe-americas',
  },
]
---

<section
  class="animate-fade-in-up mx-auto mt-8 w-full max-w-xl px-4 text-left delay-500 sm:px-6"
  aria-labelledby="topics-title"
>
  <div class="mb-4 text-center">
    <p
      class="text-primary text-xs font-bold tracking-[0.18em] uppercase"
    >
      What we cover
    </p>
    <h2 id="topics-title" class="text-foreground mt-1 text-2xl font-extrabold">
      Stories From the Community
    </h2>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
    {
      topics.map((topic) => (
        <article class="bg-card text-card-foreground ring-border/80 dark:bg-muted dark:text-foreground dark:ring-border rounded-xl p-4 shadow-[0_10px_28px_color-mix(in_oklch,var(--color-shadow)_8%,transparent)] ring-1 dark:shadow-[0_14px_34px_oklch(0_0_0_/_0.32)]">
          <div class="flex items-start gap-3">
            <span
              class="bg-primary/10 text-primary grid size-10 shrink-0 place-items-center rounded-lg"
              aria-hidden="true"
            >
              <Icon name={topic.icon} class="size-5" />
            </span>
            <div class="min-w-0">
              <h3 class="text-foreground text-base leading-tight font-bold">
                {topic.title}
              </h3>
              <p class="text-muted-foreground mt-1 text-sm leading-snug">
                {topic.description}
              </p>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
