---
import { Icon } from 'astro-icon/components'

import { IconBadge } from './ui/icon-badge'

const topics = [
  {
    title: 'Arab businesses & brands',
    description:
      'Founders, shops, products, and the work behind local success.',
    icon: 'heroicons:building-storefront',
  },
  {
    title: 'Halal food & markets',
    description:
      'Restaurants, food trucks, coffee, groceries, and halal spots.',
    icon: 'heroicons:shopping-bag',
  },
  {
    title: 'Immigrant success stories',
    description:
      'Journeys, first wins, hard lessons, and new lives in America.',
    icon: 'heroicons:map',
  },
  {
    title: 'Arab America neighborhoods',
    description:
      'Cities, communities, and Arab American life from coast to coast.',
    icon: 'heroicons:globe-americas',
  },
]
---

<section
  class="ui-section-block animate-fade-in-up mx-auto w-full max-w-xl px-4 text-left delay-500 sm:px-6"
  aria-labelledby="topics-title"
>
  <div class="ui-section-header">
    <h2 id="topics-title" class="ui-section-title">
      Stories From the Community
    </h2>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {
      topics.map((topic) => (
        <article class="ui-surface-card ui-compact-card">
          <div class="flex items-start gap-3">
            <IconBadge tone="soft" shape="square" size="lg" aria-hidden="true">
              <Icon name={topic.icon} class="size-5" />
            </IconBadge>
            <div class="min-w-0">
              <h3 class="ui-card-title text-base sm:text-base">
                {topic.title}
              </h3>
              <p class="ui-meta mt-1.5 font-normal">
                {topic.description}
              </p>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
