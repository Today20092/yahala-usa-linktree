---
import { Icon } from 'astro-icon/components'

import { IconBadge } from './ui/icon-badge'

const topics = [
  {
    title: 'Arab businesses & brands',
    description:
      'Founders, shops, products, and the work behind local success.',
    icon: 'heroicons:building-storefront',
  },
  {
    title: 'Halal food & markets',
    description:
      'Restaurants, food trucks, coffee, groceries, and halal spots.',
    icon: 'heroicons:shopping-bag',
  },
  {
    title: 'Immigrant success stories',
    description:
      'Journeys, first wins, hard lessons, and new lives in America.',
    icon: 'heroicons:map',
  },
  {
    title: 'Arab America neighborhoods',
    description:
      'Cities, communities, and Arab American life from coast to coast.',
    icon: 'heroicons:globe-americas',
  },
]
---

<section
  class="animate-fade-in-up mx-auto mt-8 w-full max-w-xl px-4 text-left delay-500 sm:px-6"
  aria-labelledby="topics-title"
>
  <div class="mb-4 text-center">
    <h2 id="topics-title" class="text-foreground text-2xl font-extrabold">
      Stories From the Community
    </h2>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
    {
      topics.map((topic) => (
        <article class="ui-surface-card p-4">
          <div class="flex items-start gap-3">
            <IconBadge tone="soft" shape="square" size="lg" aria-hidden="true">
              <Icon name={topic.icon} class="size-5" />
            </IconBadge>
            <div class="min-w-0">
              <h3 class="text-foreground text-base leading-tight font-bold">
                {topic.title}
              </h3>
              <p class="text-muted-foreground mt-1 text-sm leading-snug">
                {topic.description}
              </p>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
