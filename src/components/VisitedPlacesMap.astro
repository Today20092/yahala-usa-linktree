---
import VisitedPlacesLeafletMap from './VisitedPlacesLeafletMap'
import VisitedPlacesExplorer from './VisitedPlacesExplorer'
import type { VisitedPlaces } from '../lib/site-config'

type Props = {
  visitedPlaces: VisitedPlaces
}

const { visitedPlaces } = Astro.props
const stateGroups = visitedPlaces.stateGroups ?? []
const mapPlaces = visitedPlaces.mapPlaces ?? []
---

{
  visitedPlaces.places?.length > 0 && (
    <section
      class="ui-section-block animate-fade-in-up mx-auto w-full max-w-xl px-4 text-left delay-400 sm:px-6"
      aria-labelledby="visited-places-title"
    >
      <div class="ui-section-header">
        <h2 id="visited-places-title" class="ui-section-title">
          {visitedPlaces.title}
        </h2>
        {visitedPlaces.description && (
          <p class="ui-body mx-auto mt-3 max-w-md text-center text-sm">
            {visitedPlaces.description}
          </p>
        )}
      </div>

      <div class="ui-surface-card overflow-hidden p-2.5 sm:p-3">
        <VisitedPlacesLeafletMap client:load places={mapPlaces} />

        <VisitedPlacesExplorer client:load stateGroups={stateGroups} />
      </div>
    </section>
  )
}
