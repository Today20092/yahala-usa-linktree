---
import VisitedPlacesLeafletMap from './VisitedPlacesLeafletMap'
import VisitedPlacesExplorer from './VisitedPlacesExplorer'
import type { VisitedPlaces } from '../lib/site-config'

type Props = {
  visitedPlaces: VisitedPlaces
}

const { visitedPlaces } = Astro.props
const places = visitedPlaces.places ?? []
const stateVideos = visitedPlaces.stateVideos ?? []
const maxExplorerVideosPerGroup = 3
function toExplorerVideo(video: NonNullable<(typeof places)[number]['videos']>[number]) {
  return {
    videoId: video.videoId,
    title: video.title,
    url: video.url,
    thumbnail: video.thumbnail,
  }
}
const explorerPlaces = places.map((place) => ({
  city: place.city,
  state: place.state,
  latitude: place.latitude,
  longitude: place.longitude,
  x: place.x,
  y: place.y,
  videos: place.videos
    ?.slice(0, maxExplorerVideosPerGroup)
    .map(toExplorerVideo),
}))
const explorerStateVideos = stateVideos.map((group) => ({
  state: group.state,
  videos: group.videos.slice(0, maxExplorerVideosPerGroup).map(toExplorerVideo),
}))
---

{
  places.length > 0 && (
    <section
      class="animate-fade-in-up mx-auto mt-8 w-full max-w-xl px-4 text-left delay-400 sm:px-6"
      aria-labelledby="visited-places-title"
    >
      <div class="mb-4 text-center">
        <h2
          id="visited-places-title"
          class="text-foreground text-2xl leading-tight font-extrabold"
        >
          {visitedPlaces.title}
        </h2>
        {visitedPlaces.description && (
          <p class="text-muted-foreground mx-auto mt-2 max-w-md text-center text-sm leading-relaxed">
            {visitedPlaces.description}
          </p>
        )}
      </div>

      <div class="ui-surface-card overflow-hidden p-3 sm:p-4">
        <VisitedPlacesLeafletMap client:load places={explorerPlaces} />

        <VisitedPlacesExplorer
          client:load
          places={explorerPlaces}
          stateVideos={explorerStateVideos}
        />
      </div>
    </section>
  )
}
