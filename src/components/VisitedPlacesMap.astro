---
import { MapPin } from 'lucide-react'
import { parse } from 'yaml'

import VisitedPlacesExplorer from './VisitedPlacesExplorer'
import type { CityVideo, VisitedPlaces } from '../lib/site-config'
import visitedVideosYaml from '../data/visited-videos.yaml?raw'

type Props = {
  visitedPlaces: VisitedPlaces
}

const { visitedPlaces } = Astro.props
const places = visitedPlaces.places ?? []
const stateVideoGroups = visitedPlaces.stateVideos ?? []
const visitedVideoCatalog = parse(visitedVideosYaml) as {
  videos?: Array<CityVideo & { state?: string | null; city?: string | null }>
}
const tileZoom = 4
const tileColumns = [2, 3, 4, 5]
const tileRows = [5, 6]
const tileBounds = {
  minX: tileColumns[0],
  maxX: tileColumns[tileColumns.length - 1] + 1,
  minY: tileRows[0],
  maxY: tileRows[tileRows.length - 1] + 1,
}

const stateAbbreviations = new Map([
  ['Alabama', 'AL'],
  ['Alaska', 'AK'],
  ['Arizona', 'AZ'],
  ['Arkansas', 'AR'],
  ['California', 'CA'],
  ['Colorado', 'CO'],
  ['Connecticut', 'CT'],
  ['Delaware', 'DE'],
  ['Florida', 'FL'],
  ['Georgia', 'GA'],
  ['Hawaii', 'HI'],
  ['Idaho', 'ID'],
  ['Illinois', 'IL'],
  ['Indiana', 'IN'],
  ['Iowa', 'IA'],
  ['Kansas', 'KS'],
  ['Kentucky', 'KY'],
  ['Louisiana', 'LA'],
  ['Maine', 'ME'],
  ['Maryland', 'MD'],
  ['Massachusetts', 'MA'],
  ['Michigan', 'MI'],
  ['Minnesota', 'MN'],
  ['Mississippi', 'MS'],
  ['Missouri', 'MO'],
  ['Montana', 'MT'],
  ['Nebraska', 'NE'],
  ['Nevada', 'NV'],
  ['New Hampshire', 'NH'],
  ['New Jersey', 'NJ'],
  ['New Mexico', 'NM'],
  ['New York', 'NY'],
  ['North Carolina', 'NC'],
  ['North Dakota', 'ND'],
  ['Ohio', 'OH'],
  ['Oklahoma', 'OK'],
  ['Oregon', 'OR'],
  ['Pennsylvania', 'PA'],
  ['Rhode Island', 'RI'],
  ['South Carolina', 'SC'],
  ['South Dakota', 'SD'],
  ['Tennessee', 'TN'],
  ['Texas', 'TX'],
  ['Utah', 'UT'],
  ['Vermont', 'VT'],
  ['Virginia', 'VA'],
  ['Washington', 'WA'],
  ['West Virginia', 'WV'],
  ['Wisconsin', 'WI'],
  ['Wyoming', 'WY'],
])
const statesByAbbreviation = new Map(
  [...stateAbbreviations.entries()].map(([state, abbreviation]) => [
    abbreviation.toLowerCase(),
    state,
  ]),
)

const formatPlace = (city: string, state: string) =>
  `${city}, ${stateAbbreviations.get(state) ?? state}`

const normalizeState = (state?: string | null) => {
  const normalized = state?.trim()
  if (!normalized) return ''

  return (
    statesByAbbreviation.get(normalized.toLowerCase()) ?? normalized
  ).toLowerCase()
}

const normalizeCity = (city?: string | null) => city?.trim().toLowerCase() ?? ''

type YoutubeOembed = {
  title?: string
  thumbnail_url?: string
}

const getYoutubeVideoId = (url: string) => {
  try {
    const parsedUrl = new URL(url)

    if (parsedUrl.hostname.includes('youtu.be')) {
      return parsedUrl.pathname.split('/').filter(Boolean)[0]
    }

    if (parsedUrl.searchParams.has('v')) {
      return parsedUrl.searchParams.get('v')
    }

    return parsedUrl.pathname.match(/\/embed\/([^/?]+)/)?.[1] ?? null
  } catch {
    return null
  }
}

const getVideoKey = (url: string) => {
  const videoId = getYoutubeVideoId(url)
  if (videoId) return `youtube:${videoId}`

  try {
    const parsedUrl = new URL(url)
    parsedUrl.search = ''
    parsedUrl.hash = ''
    return parsedUrl.toString()
  } catch {
    return url
  }
}

const youtubeThumbnailUrl = (url: string) => {
  const videoId = getYoutubeVideoId(url)
  return videoId ? `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg` : undefined
}

const getYoutubeMetadata = async (url: string): Promise<YoutubeOembed> => {
  try {
    const response = await fetch(
      `https://www.youtube.com/oembed?url=${encodeURIComponent(url)}&format=json`,
    )

    if (!response.ok) return {}

    return (await response.json()) as YoutubeOembed
  } catch {
    return {}
  }
}

const resolveVideo = async (video: CityVideo): Promise<CityVideo> => {
  if (video.title && video.thumbnail) return video

  const metadata = await getYoutubeMetadata(video.url)

  return {
    ...video,
    title: video.title ?? metadata.title ?? 'Watch on YouTube',
    thumbnail: video.thumbnail ?? metadata.thumbnail_url ?? youtubeThumbnailUrl(video.url),
  }
}

const dedupeVideos = (videos: CityVideo[]) => {
  const seen = new Set<string>()

  return videos.filter((video) => {
    const key = getVideoKey(video.url)
    if (seen.has(key)) return false

    seen.add(key)
    return true
  })
}

const videosByState = new Map<string, CityVideo[]>()
const videosByPlace = new Map<string, CityVideo[]>()

const addVideoToMap = (map: Map<string, CityVideo[]>, key: string, video: CityVideo) => {
  const videos = map.get(key) ?? []
  videos.push(video)
  map.set(key, videos)
}

for (const group of stateVideoGroups) {
  videosByState.set(normalizeState(group.state), group.videos ?? [])
}

for (const video of visitedVideoCatalog.videos ?? []) {
  const state = normalizeState(video.state)
  if (!state) continue

  const city = normalizeCity(video.city)
  const catalogVideo = {
    title: video.title,
    url: video.url,
    thumbnail: video.thumbnail,
  }

  if (city) {
    addVideoToMap(videosByPlace, `${state}:${city}`, catalogVideo)
  } else {
    addVideoToMap(videosByState, state, catalogVideo)
  }
}

const resolvedPlaces = await Promise.all(
  places.map(async (place) => {
    const state = normalizeState(place.state)
    const city = normalizeCity(place.city)
    const inheritedVideos = videosByState.get(state) ?? []
    const assignedCityVideos = videosByPlace.get(`${state}:${city}`) ?? []
    const mergedVideos = dedupeVideos([
      ...inheritedVideos,
      ...assignedCityVideos,
      ...(place.videos ?? []),
    ])

    return {
      ...place,
      videos:
        mergedVideos.length > 0
          ? await Promise.all(mergedVideos.map((video) => resolveVideo(video)))
          : undefined,
    }
  }),
)

const getPlacePosition = (place: (typeof places)[number]) => {
  if (
    typeof place.latitude === 'number' &&
    typeof place.longitude === 'number'
  ) {
    const tileCount = 2 ** tileZoom
    const tileX = ((place.longitude + 180) / 360) * tileCount
    const latitudeRadians = (place.latitude * Math.PI) / 180
    const tileY =
      ((1 -
        Math.log(Math.tan(latitudeRadians) + 1 / Math.cos(latitudeRadians)) /
          Math.PI) /
        2) *
      tileCount

    return {
      x: ((tileX - tileBounds.minX) / (tileBounds.maxX - tileBounds.minX)) * 100,
      y: ((tileY - tileBounds.minY) / (tileBounds.maxY - tileBounds.minY)) * 100,
    }
  }

  return {
    x: place.x ?? 50,
    y: place.y ?? 50,
  }
}
---

{
  places.length > 0 && (
    <section
      class="animate-fade-in-up mx-auto mt-8 w-full max-w-xl px-4 text-left delay-400 sm:px-6"
      aria-labelledby="visited-places-title"
    >
      <div class="mb-4 text-center">
        {visitedPlaces.eyebrow && (
          <p class="text-primary text-xs font-bold tracking-[0.18em] uppercase">
            {visitedPlaces.eyebrow}
          </p>
        )}
        <h2
          id="visited-places-title"
          class="text-foreground mt-1 text-2xl leading-tight font-extrabold"
        >
          {visitedPlaces.title}
        </h2>
        {visitedPlaces.description && (
          <p class="text-muted-foreground mx-auto mt-2 max-w-md text-center text-sm leading-relaxed">
            {visitedPlaces.description}
          </p>
        )}
      </div>

      <div class="bg-card text-card-foreground ring-border/80 dark:bg-muted dark:text-foreground dark:ring-border overflow-hidden rounded-xl border border-border/70 p-3 shadow-[0_10px_28px_color-mix(in_oklch,var(--color-shadow)_8%,transparent)] ring-1 dark:shadow-[0_14px_34px_oklch(0_0_0_/_0.30)] sm:p-4">
        <div class="bg-muted dark:bg-background/35 relative aspect-[2/1] overflow-hidden rounded-lg border border-border/70 shadow-inner">
          <div
            class="absolute inset-0 grid grid-cols-4 grid-rows-2"
            aria-hidden="true"
          >
            {tileRows.flatMap((row) =>
              tileColumns.map((column) => (
                <img
                  src={`https://tile.openstreetmap.org/${tileZoom}/${column}/${row}.png`}
                  alt=""
                  class="h-full w-full object-cover"
                  loading="eager"
                  decoding="async"
                  referrerpolicy="no-referrer"
                />
              )),
            )}
          </div>
          <div class="absolute inset-0 bg-background/10 mix-blend-screen dark:bg-background/15" />

          {places.map((place) => {
            const label = formatPlace(place.city, place.state)
            const position = getPlacePosition(place)

            return (
              <span
                class="group absolute grid size-3.5 -translate-x-1/2 -translate-y-full place-items-center rounded-full text-foreground/75"
                style={`left: ${position.x}%; top: ${position.y}%;`}
                title={label}
              >
                <span
                  class="grid size-3.5 place-items-center rounded-full bg-background/95 shadow-[0_5px_14px_color-mix(in_oklch,var(--color-shadow)_20%,transparent)] ring-1 ring-border backdrop-blur-sm dark:bg-card/95"
                  aria-hidden="true"
                >
                  <MapPin
                    size={10}
                    strokeWidth={3}
                    fill="currentColor"
                  />
                </span>
                <span class="pointer-events-none absolute bottom-full left-1/2 mb-2 -translate-x-1/2 rounded-md bg-foreground px-2 py-1 text-xs font-semibold whitespace-nowrap text-background opacity-0 shadow-lg transition group-hover:opacity-100">
                  {label}
                </span>
              </span>
            )
          })}

          <a
            href="https://www.openstreetmap.org/copyright"
            target="_blank"
            rel="noopener noreferrer"
            class="absolute right-2 bottom-2 rounded bg-background/90 px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground shadow-sm backdrop-blur-sm"
          >
            © OpenStreetMap
          </a>
        </div>

        <VisitedPlacesExplorer client:load places={resolvedPlaces} />
      </div>
    </section>
  )
}
