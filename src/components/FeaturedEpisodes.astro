---
import { Icon } from 'astro-icon/components'

import { IconBadge } from './ui/icon-badge'

import latestYoutubeVideos from '../data/latest-youtube-videos.json'
import { youtubeVideosById } from '../lib/youtube-videos'
import { siteConfig } from '../lib/site-config'

type Episode = {
  thumbnail: string
  title: string
  href: string
  viewCount: number
}

type ChannelVideoSummary = {
  topVideoIds?: string[]
}

const primaryChannel = siteConfig.youtubeChannels[0]
const primaryChannelSummary = primaryChannel
  ? (latestYoutubeVideos as Record<string, ChannelVideoSummary>)[
      primaryChannel.id
    ]
  : undefined

const formatViews = (views: number) =>
  Intl.NumberFormat('en', {
    notation: views >= 10000 ? 'compact' : 'standard',
    maximumFractionDigits: views >= 10000 ? 1 : 0,
  }).format(views)

const youtubeThumbnailUrl = (videoId: string) =>
  `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`

const videosWithViews = Object.values(youtubeVideosById)
  .filter((video) => Number.isFinite(Number(video.viewCount)) && !video.isShort)
  .sort((a, b) => Number(b.viewCount) - Number(a.viewCount))

const topVideoIds =
  primaryChannelSummary?.topVideoIds?.length === 3
    ? primaryChannelSummary.topVideoIds
    : videosWithViews.slice(0, 3).map((video) => video.videoId)

const episodes = topVideoIds
  .map((videoId): Episode | null => {
    const video = youtubeVideosById[videoId]
    const viewCount = Number(video?.viewCount)
    if (!video || !Number.isFinite(viewCount)) return null

    return {
      thumbnail: video.thumbnail ?? youtubeThumbnailUrl(videoId),
      title: video.title ?? 'Watch this episode',
      href: video.url ?? `https://www.youtube.com/watch?v=${videoId}`,
      viewCount,
    }
  })
  .filter((episode): episode is Episode => Boolean(episode))
---

{
  episodes.length > 0 && (
    <section
      class="animate-fade-in-up mx-auto mt-8 w-full max-w-xl px-4 text-left delay-400 sm:px-6"
      aria-labelledby="featured-episodes-title"
    >
      <div class="mb-4 text-center">
        <p class="text-primary text-xs font-bold tracking-widest uppercase">
          Watch next
        </p>
        <h2
          id="featured-episodes-title"
          class="text-foreground mt-1 text-2xl font-extrabold"
        >
          Most Viewed Episodes
        </h2>
      </div>

      <div class="grid gap-3">
        {episodes.map((episode) => (
          <article class="ui-surface-card overflow-hidden text-left transition-shadow duration-200 hover:elevation-4">
            <a
              href={episode.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group focus-visible:ring-ring/30 focus-visible:ring-offset-background flex items-center gap-4 px-3 py-3 transition-transform duration-200 hover:-translate-y-0.5 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none sm:gap-5 sm:px-4 sm:py-4"
              aria-label={`Watch on YouTube: ${episode.title}`}
            >
              <span class="bg-muted relative aspect-video w-36 shrink-0 overflow-hidden rounded-md shadow-sm ring-1 ring-black/5 sm:w-48">
                <img
                  src={episode.thumbnail}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
                <span
                  class="absolute inset-0 grid place-items-center bg-scrim/10 opacity-0 transition-opacity group-hover:opacity-100 group-focus-visible:opacity-100"
                  aria-hidden="true"
                >
                  <IconBadge tone="solid" size="md" class="shadow-lg">
                    <Icon
                      name="heroicons:play-solid"
                      class="size-4 translate-x-px"
                    />
                  </IconBadge>
                </span>
              </span>

              <span class="min-w-0 py-0.5">
                <span class="text-primary text-xs leading-none font-bold tracking-wide uppercase">
                  Most viewed episode
                </span>
                <h3
                  lang="ar"
                  dir="rtl"
                  class="text-foreground mt-2 line-clamp-2 text-base leading-snug font-extrabold sm:text-xl"
                >
                  {episode.title}
                </h3>
                <span class="text-muted-foreground mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm leading-none font-semibold">
                  <span class="inline-flex items-center gap-1.5">
                    <Icon
                      name="heroicons:eye"
                      class="size-4"
                      aria-hidden="true"
                    />
                    {formatViews(episode.viewCount)} views
                  </span>
                  <span class="inline-flex items-center gap-1.5">
                    YouTube
                    <Icon
                      name="heroicons:arrow-up-right"
                      class="size-4"
                      aria-hidden="true"
                    />
                  </span>
                </span>
              </span>
            </a>
          </article>
        ))}
      </div>
    </section>
  )
}
