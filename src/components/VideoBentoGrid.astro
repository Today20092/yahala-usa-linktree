---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import { parse } from 'yaml'

import { IconBadge } from './ui/icon-badge'
import latestYoutubeVideos from '../data/latest-youtube-videos.json'
import visitedVideosYaml from '../data/visited-videos.yaml?raw'
import { siteConfig } from '../lib/site-config'
import { resolveYoutubeVideos } from '../lib/youtube-videos'

type BentoImage = {
  type: 'video'
  src: string | ImageMetadata
  alt: string
  href: string
}

type StatTile = {
  type: 'stat'
  platform: string
  metric: string
  value: string
  icon: string
  accent: string
  darkAccent: string
  tint: string
  darkTint: string
}

type BentoTile = BentoImage | StatTile

type GeneratedYoutubeVideo = {
  videoId: string
  title: string
  url: string
  thumbnail: string
}

type VisitedVideoCatalog = {
  videos?: {
    videoId?: string
    title?: string
    url?: string
    thumbnail?: string
  }[]
}

const bentoImageModules = import.meta.glob('../bento/*.{png,jpg,jpeg,webp}', {
  eager: true,
  import: 'default',
})

const socialReach = siteConfig.socialReach
const youtubeChannelUrl =
  siteConfig.socialLinks.find((link) => link.id === 'youtube')?.url ??
  siteConfig.youtubeChannels[0]?.videosUrl ??
  'https://www.youtube.com/'
const youtubeVideoUrl = (videoId: string) =>
  `https://www.youtube.com/watch?v=${videoId}`

const formatStat = (value: number) => {
  const formatter = new Intl.NumberFormat('en-US', {
    maximumFractionDigits: value >= 1000000 ? 1 : 0,
  })

  if (value >= 1000000) return `${formatter.format(value / 1000000)}M`
  if (value >= 1000) return `${formatter.format(value / 1000)}K`
  return formatter.format(value)
}

const platformIcons: Record<string, string> = {
  YouTube: 'simple-icons:youtube',
  TikTok: 'simple-icons:tiktok',
  Instagram: 'simple-icons:instagram',
  Facebook: 'simple-icons:facebook',
}

const platformColors: Record<
  string,
  {
    accent: string
    darkAccent: string
    tint: string
    darkTint: string
  }
> = {
  YouTube: {
    accent: '#ff0000',
    darkAccent: '#ff5f5f',
    tint: '#fff1f1',
    darkTint: '#2a1010',
  },
  TikTok: {
    accent: '#010101',
    darkAccent: '#25f4ee',
    tint: '#f3f4f6',
    darkTint: '#0b1f20',
  },
  Instagram: {
    accent: '#e4405f',
    darkAccent: '#ff7a9a',
    tint: '#fff1f6',
    darkTint: '#2a101b',
  },
  Facebook: {
    accent: '#1877f2',
    darkAccent: '#74a7ff',
    tint: '#eef5ff',
    darkTint: '#0b1a2e',
  },
}

const statPlatformPriority = ['TikTok', 'YouTube', 'Instagram', 'Facebook']
const statMetricPriority = [
  'Views',
  'Reach',
  'Likes',
  'Posts',
  'Followers',
  'Subscribers',
]
const statTiles = socialReach.items
  .sort((a, b) => {
    const platformComparison =
      statPlatformPriority.indexOf(a.platform) -
      statPlatformPriority.indexOf(b.platform)

    if (platformComparison !== 0) return platformComparison

    return (
      statMetricPriority.indexOf(a.metric) -
      statMetricPriority.indexOf(b.metric)
    )
  })
  .map((item) => {
    const colors = platformColors[item.platform] ?? {
      accent: 'var(--primary)',
      darkAccent: 'var(--primary)',
      tint: 'var(--accent)',
      darkTint: 'var(--accent)',
    }

    return {
      type: 'stat' as const,
      platform: item.platform,
      metric: item.metric,
      value: formatStat(item.value),
      icon: platformIcons[item.platform] ?? 'heroicons:chart-bar',
      ...colors,
    }
  })

const bentoImages = Object.entries(bentoImageModules)
  .filter(([path]) => !path.includes('.DS_Store'))
  .map(([path, image]): BentoImage => {
    const filename = decodeURIComponent(path.split('/').pop() ?? '')
    const videoId = filename.match(/\[([A-Za-z0-9_-]{11})\b/)?.[1]
    const title = filename
      .replace(/\.[^.]+$/, '')
      .replace(/\s*\[[^\]]+\](?:\s*\(\d+\))?$/, '')
      .replace(/^Ya Hala with Haithum ياهلا مع هيثم\s*-\s*/, '')
      .trim()

    return {
      type: 'video',
      src: image as ImageMetadata,
      alt: title || 'Ya Hala YouTube video screenshot',
      href: videoId ? youtubeVideoUrl(videoId) : youtubeChannelUrl,
    }
  })
  .sort((a, b) => {
    const seedA = Array.from(a.alt).reduce((sum, char) => {
      return sum + char.charCodeAt(0)
    }, 0)
    const seedB = Array.from(b.alt).reduce((sum, char) => {
      return sum + char.charCodeAt(0)
    }, 0)

    return (seedA % 997) - (seedB % 997)
  })

const generatedYoutubeImages = Object.values(latestYoutubeVideos)
  .flatMap(
    (channel) => (channel as { videos?: GeneratedYoutubeVideo[] }).videos ?? [],
  )
  .map(
    (video): BentoImage => ({
      type: 'video',
      src: video.thumbnail,
      alt: video.title || 'Ya Hala YouTube video thumbnail',
      href: video.url || youtubeVideoUrl(video.videoId),
    }),
  )

const visitedVideoImages = resolveYoutubeVideos(
  (parse(visitedVideosYaml) as VisitedVideoCatalog).videos ?? [],
).map(
  (video): BentoImage => ({
    type: 'video',
    src: video.thumbnail,
    alt: video.title || 'Ya Hala YouTube video thumbnail',
    href: video.url || youtubeVideoUrl(video.videoId),
  }),
)

const dedupeImagesByHref = (images: BentoImage[]) => {
  const seen = new Set<string>()

  return images.filter((image) => {
    if (seen.has(image.href)) return false

    seen.add(image.href)
    return true
  })
}

const getImageKey = (image: BentoImage) => image.href

const getStatKey = (stat: StatTile) =>
  `${stat.platform}::${stat.metric}::${stat.value}`

const pickNextUnusedStat = (
  usedKeys: Set<string>,
  startIndex: number,
): StatTile | undefined => {
  if (statTiles.length === 0) return undefined

  for (let offset = 0; offset < statTiles.length; offset += 1) {
    const stat = statTiles[(startIndex + offset) % statTiles.length]

    if (!usedKeys.has(getStatKey(stat))) return stat
  }

  return undefined
}

const videoThumbnailImages = dedupeImagesByHref([
  ...generatedYoutubeImages,
  ...visitedVideoImages,
])
const bentoImageHrefs = new Set(videoThumbnailImages.map((image) => image.href))
const maxCarouselImages = 36
const carouselImages = [
  ...videoThumbnailImages,
  ...bentoImages.filter((image) => !bentoImageHrefs.has(image.href)),
].slice(0, maxCarouselImages)

const rowCount = 3
const bentoRows = Array.from({ length: rowCount }, (_, rowIndex) => {
  const rowImages = carouselImages.filter(
    (_, index) => index % rowCount === rowIndex,
  )
  const usedKeys = new Set<string>()
  const rowTiles: BentoTile[] = []

  rowImages.forEach((image, index) => {
    const imageKey = getImageKey(image)
    if (usedKeys.has(imageKey)) return

    usedKeys.add(imageKey)
    rowTiles.push(image)

    const shouldInsertStat =
      index === 1 || (index > 1 && (index + rowIndex) % 4 === 1)
    if (!shouldInsertStat) return

    const statTile = pickNextUnusedStat(usedKeys, index + rowIndex * 2)
    if (!statTile) return

    usedKeys.add(getStatKey(statTile))
    rowTiles.push(statTile)
  })

  if (process.env.NODE_ENV !== 'production') {
    const uniqueKeys = new Set(
      rowTiles.map((tile) =>
        tile.type === 'video' ? getImageKey(tile) : getStatKey(tile),
      ),
    )

    if (uniqueKeys.size !== rowTiles.length) {
      throw new Error(
        `Duplicate carousel tile detected in row ${rowIndex + 1}.`,
      )
    }
  }

  return rowTiles
})
---

{
  carouselImages.length > 0 && (
    <section
      class="animate-fade-in-up mx-auto mt-6 w-full max-w-xl px-4 delay-300 sm:px-6"
      aria-label="Ya Hala videos and social reach"
    >
      <div class="ui-surface-card overflow-hidden">
        <div class="border-border/70 bg-card/80 flex items-center justify-between gap-3 border-b px-3 py-2 text-left sm:px-4">
          <div class="flex items-center gap-2">
            <IconBadge
              tone="solid"
              size="md"
              style={{
                '--ui-icon-badge-accent': 'var(--primary)',
                '--ui-icon-badge-foreground': 'var(--primary-foreground)',
              }}
              class="shadow-sm"
            >
              <Icon
                name="heroicons:play-20-solid"
                class="size-4"
                aria-hidden="true"
              />
            </IconBadge>
            <p class="text-sm leading-tight font-semibold">
              Tap any video to view
            </p>
          </div>
          <span class="text-muted-foreground hidden text-xs font-medium sm:inline">
            Drag to browse
          </span>
        </div>
        <div class="bento-scroll-mask space-y-2 overflow-hidden p-3 sm:space-y-3">
          {bentoRows.map((row, rowIndex) => (
            <div class="bento-scroll-row overflow-hidden">
              <div
                class:list={[
                  'bento-scroll-track flex w-max gap-2 sm:gap-3',
                  `bento-scroll-track-${rowIndex + 1}`,
                ]}
              >
                {[...row, ...row].map((item) =>
                  item.type === 'video' ? (
                    <a
                      href={item.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Open on YouTube: ${item.alt}`}
                      class="group bento-video-link bg-accent focus-visible:outline-ring dark:bg-accent border-border/60 hover:border-youtube/70 hover:ring-youtube/30 dark:border-border dark:hover:border-youtube/70 relative isolate block aspect-video w-[252px] shrink-0 cursor-pointer overflow-hidden rounded-lg border text-left shadow-sm ring-1 ring-transparent transition duration-200 hover:-translate-y-0.5 hover:shadow-lg focus-visible:outline-3 focus-visible:outline-offset-2 sm:w-[274px]"
                    >
                      <Image
                        src={item.src}
                        alt={item.alt}
                        width={480}
                        height={270}
                        class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                        loading="eager"
                        decoding="async"
                      />
                      <span
                        class="absolute inset-x-0 bottom-0 z-10 flex items-end justify-between gap-3 bg-gradient-to-t from-scrim/80 via-scrim/40 to-transparent p-3 pt-10 text-white opacity-95 transition duration-200 group-hover:opacity-100"
                        aria-hidden="true"
                      >
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-background/95 px-2.5 py-1 text-xs font-bold text-foreground shadow-sm ring-1 ring-border backdrop-blur-sm dark:bg-card/90">
                          <IconBadge tone="solid" size="xs">
                            <Icon
                              name="heroicons:play-20-solid"
                              class="size-3"
                            />
                          </IconBadge>
                        </span>
                        <IconBadge
                          tone="solid"
                          size="sm"
                          class="transition duration-200 group-hover:scale-110"
                        >
                          <Icon
                            name="heroicons:arrow-top-right-on-square-20-solid"
                            class="size-4"
                          />
                        </IconBadge>
                      </span>
                    </a>
                  ) : (
                    <div
                      style={`--platform-accent: ${item.accent}; --platform-accent-dark: ${item.darkAccent}; --platform-tint: ${item.tint}; --platform-tint-dark: ${item.darkTint};`}
                      aria-label={`${item.platform} ${item.metric}: ${item.value}`}
                      class="bg-card/90 border-border/60 hover:shadow-md dark:border-border/70 dark:bg-card/75 relative flex aspect-video w-[252px] shrink-0 cursor-default flex-col justify-between overflow-hidden rounded-lg border p-4 text-left shadow-sm transition duration-200 [--platform-active-accent:var(--platform-accent)] [--platform-active-tint:var(--platform-tint)] sm:w-[274px] dark:[--platform-active-accent:var(--platform-accent-dark)] dark:[--platform-active-tint:var(--platform-tint-dark)]"
                    >
                      <span
                        class="absolute inset-x-0 top-0 h-1 bg-[var(--platform-active-accent)]"
                        aria-hidden="true"
                      />
                      <span
                        class="absolute inset-0 bg-[linear-gradient(135deg,color-mix(in_srgb,var(--platform-active-tint)_42%,transparent)_0%,transparent_58%)]"
                        aria-hidden="true"
                      />
                      <div class="relative flex min-w-0 items-center gap-2">
                        <span class="grid size-7 shrink-0 place-items-center rounded-full bg-[color-mix(in_srgb,var(--platform-active-accent)_12%,var(--card))] ring-1 ring-[color-mix(in_srgb,var(--platform-active-accent)_18%,transparent)]">
                          <Icon
                            name={item.icon}
                            class="size-3.5 shrink-0 text-[var(--platform-active-accent)]"
                            aria-hidden="true"
                          />
                        </span>
                        <p class="text-foreground truncate text-sm font-semibold">
                          {item.platform}
                        </p>
                      </div>
                      <div class="relative">
                        <p class="text-foreground text-3xl leading-none font-black tracking-normal tabular-nums sm:text-4xl">
                          {item.value}
                        </p>
                        <p class="text-muted-foreground mt-2 truncate text-xs font-bold tracking-normal uppercase">
                          {item.metric}
                        </p>
                      </div>
                    </div>
                  ),
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<script>
  const marqueeMask = document.querySelector('.bento-scroll-mask')
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches

  if (marqueeMask instanceof HTMLElement && !prefersReducedMotion) {
    const rows = [...marqueeMask.querySelectorAll('.bento-scroll-row')].map(
      (row, index) => {
        const track = row.querySelector('.bento-scroll-track')
        const baseDurations = [90, 100, 70]
        const width =
          track instanceof HTMLElement ? track.scrollWidth / 2 : 274 * 8

        return {
          row,
          track,
          x: 0,
          speed: -width / baseDurations[index % baseDurations.length],
          dragVelocity: 0,
        }
      },
    )

    let lastFrame = performance.now()
    let activeRow = null
    let activePointer = null
    let lastPointerX = 0
    let lastPointerTime = 0
    let dragDistance = 0

    const wrap = (value, width) => {
      if (!width) return value
      while (value <= -width) value += width
      while (value > 0) value -= width
      return value
    }

    const animate = (time) => {
      const delta = Math.min((time - lastFrame) / 1000, 0.05)
      lastFrame = time

      for (const state of rows) {
        if (!(state.track instanceof HTMLElement)) continue

        const width = state.track.scrollWidth / 2
        if (state !== activeRow) {
          state.x += (state.speed + state.dragVelocity) * delta
          state.dragVelocity *= Math.pow(0.08, delta)
        }

        state.x = wrap(state.x, width)
        state.track.style.transform = `translate3d(${state.x}px, 0, 0)`
      }

      requestAnimationFrame(animate)
    }

    marqueeMask.classList.add('is-drag-ready')
    requestAnimationFrame(animate)

    for (const state of rows) {
      state.row.addEventListener('pointerdown', (event) => {
        activeRow = state
        activePointer = event.pointerId
        lastPointerX = event.clientX
        lastPointerTime = performance.now()
        dragDistance = 0
        state.dragVelocity = 0
        state.row.setPointerCapture(event.pointerId)
      })

      state.row.addEventListener('pointermove', (event) => {
        if (activeRow !== state || activePointer !== event.pointerId) return

        const now = performance.now()
        const deltaX = event.clientX - lastPointerX
        const deltaTime = Math.max(now - lastPointerTime, 1)

        state.x += deltaX
        state.dragVelocity = (deltaX / deltaTime) * 1000
        dragDistance += Math.abs(deltaX)
        lastPointerX = event.clientX
        lastPointerTime = now
      })

      state.row.addEventListener('pointerup', (event) => {
        if (activeRow !== state || activePointer !== event.pointerId) return
        activeRow = null
        activePointer = null
      })

      state.row.addEventListener('pointercancel', () => {
        activeRow = null
        activePointer = null
      })

      state.row.addEventListener(
        'click',
        (event) => {
          if (dragDistance > 12) {
            event.preventDefault()
            event.stopPropagation()
          }
        },
        true,
      )
    }
  }
</script>
