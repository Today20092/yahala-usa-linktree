---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { buttonVariants } from '@/components/ui/button'
import {
  Card,
  CardContent,
  CardFooter,
  CardHeader,
  CardTitle,
} from '@/components/ui/card'
import { Icon } from 'astro-icon/components'
import type { PeopleInterviewed } from '@/lib/site-config'

type Props = {
  peopleInterviewed?: PeopleInterviewed
}

const { peopleInterviewed } = Astro.props
const people = peopleInterviewed?.people ?? []
const portraitImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/people/*.{jpeg,jpg,png,webp}',
  { eager: true },
)

const getPortraitImage = (imagePath: string) => {
  const image = portraitImages[imagePath]?.default

  if (!image) {
    throw new Error(`Interview portrait not found: ${imagePath}`)
  }

  return image
}
---

{
  peopleInterviewed && people.length > 0 && (
    <section
      class="animate-fade-in-up mx-auto mt-8 w-full max-w-5xl px-4 text-left delay-400 sm:px-6"
      aria-labelledby="people-interviewed-title"
    >
      <div class="mx-auto mb-4 max-w-xl text-center">
        <p class="text-primary text-xs font-bold tracking-[0.18em] uppercase">
          {peopleInterviewed.eyebrow}
        </p>
        <h2
          id="people-interviewed-title"
          class="text-foreground mt-1 text-2xl font-extrabold"
        >
          {peopleInterviewed.title}
        </h2>
        {peopleInterviewed.description && (
          <p class="text-muted-foreground mx-auto mt-2 max-w-prose text-sm leading-relaxed">
            {peopleInterviewed.description}
          </p>
        )}
      </div>

      <div
        class="flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2"
        aria-label="Scrollable list of interviewed people"
      >
        {people.map((person) => (
          <Card
            size="sm"
            className="elevation-2 hover:elevation-4 w-[72vw] max-w-[15.5rem] min-w-[13.5rem] snap-start gap-3 transition-shadow duration-200 sm:w-[14.75rem] sm:min-w-[14.75rem] lg:w-[14.75rem] lg:min-w-[14.75rem]"
          >
            <Image
              src={getPortraitImage(person.image)}
              alt={person.imageAlt}
              class="bg-muted aspect-square w-full object-cover"
              loading="lazy"
              decoding="async"
              widths={[320, 480]}
              sizes="(min-width: 640px) 236px, 72vw"
            />
            <CardHeader className="gap-1">
              <CardTitle className="text-foreground text-base leading-tight font-bold">
                {person.name}
              </CardTitle>
              <p class="text-primary line-clamp-2 text-xs leading-snug font-bold">
                {person.title}
              </p>
            </CardHeader>
            <CardContent className="flex-1">
              <p class="text-muted-foreground line-clamp-3 text-xs leading-relaxed">
                {person.bio}
              </p>
            </CardContent>
            <CardFooter className="border-t-0 bg-transparent pt-0">
              <a
                href={person.videoUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Watch ${person.name}'s interview on YouTube`}
                class={buttonVariants({
                  size: 'sm',
                  className: 'w-full',
                })}
              >
                <Icon
                  name="heroicons:play-circle"
                  data-icon="inline-start"
                  aria-hidden="true"
                />
                Watch Interview
              </a>
            </CardFooter>
          </Card>
        ))}
      </div>
    </section>
  )
}
