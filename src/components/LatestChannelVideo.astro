---
import { Icon } from 'astro-icon/components'

import { IconBadge } from './ui/icon-badge'
import {
  getYoutubeVideoId,
  youtubeThumbnailFallbackUrl,
} from '../lib/youtube-videos'

type Video = {
  title: string
  url: string
  thumbnail: string
  published?: string
}

type LatestChannelVideoProps = {
  channelName: string
  channelDescription: string
  channelLogoSrc: string
  channelAccentColor: string
  channelDarkAccentColor: string
  channelCardBackground: string
  channelDarkCardBackground: string
  channelCardTint: string
  channelDarkCardTint: string
  channelLogoBackgroundColor: string
  channelDarkLogoBackgroundColor?: string
  channelLogoFit?: 'cover' | 'contain'
  channelLogoPaddingClass?: string
  video: Video
}

const {
  channelName,
  channelDescription,
  channelLogoSrc,
  channelAccentColor,
  channelDarkAccentColor,
  channelCardBackground,
  channelDarkCardBackground,
  channelCardTint,
  channelDarkCardTint,
  channelLogoBackgroundColor,
  channelDarkLogoBackgroundColor,
  channelLogoFit = 'cover',
  channelLogoPaddingClass = '',
  video,
} = Astro.props as LatestChannelVideoProps

const publishedAt = video.published ? new Date(video.published) : null
const publishedDate =
  publishedAt && !Number.isNaN(publishedAt.getTime())
    ? new Intl.DateTimeFormat('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
      }).format(publishedAt)
    : ''
const videoId = getYoutubeVideoId(video.url)
const thumbnailFallback = videoId ? youtubeThumbnailFallbackUrl(videoId) : ''
---

<div class="mx-auto w-full max-w-xl px-4 sm:px-6">
  <a
    href={video.url}
    target="_blank"
    rel="noopener noreferrer"
    style={`--channel-accent: ${channelAccentColor}; --channel-accent-dark: ${channelDarkAccentColor}; --channel-card-bg: ${channelCardBackground}; --channel-card-bg-dark: ${channelDarkCardBackground}; --channel-card-tint: ${channelCardTint}; --channel-card-tint-dark: ${channelDarkCardTint}; --channel-logo-bg: ${channelLogoBackgroundColor}; --channel-logo-bg-dark: ${
      channelDarkLogoBackgroundColor ?? channelLogoBackgroundColor
    };`}
    class="group text-foreground focus-visible:ring-offset-background elevation-3 hover:elevation-4 block w-full overflow-hidden rounded-xl bg-[linear-gradient(180deg,var(--channel-active-tint),var(--channel-active-bg)_42%)] text-left ring-1 ring-[color-mix(in_srgb,var(--channel-active-accent)_22%,transparent)] transition-all duration-300 ease-out [--channel-active-accent:var(--channel-accent)] [--channel-active-bg:var(--channel-card-bg)] [--channel-active-logo-bg:var(--channel-logo-bg)] [--channel-active-tint:var(--channel-card-tint)] hover:-translate-y-1 hover:scale-[1.02] hover:ring-[color-mix(in_srgb,var(--channel-active-accent)_36%,transparent)] focus-visible:ring-2 focus-visible:ring-[var(--channel-active-accent)] focus-visible:ring-offset-2 focus-visible:outline-none active:translate-y-0 active:scale-[0.98] dark:[--channel-active-accent:var(--channel-accent-dark)] dark:[--channel-active-bg:var(--channel-card-bg-dark)] dark:[--channel-active-logo-bg:var(--channel-logo-bg-dark)] dark:[--channel-active-tint:var(--channel-card-tint-dark)]"
  >
    <span class="bg-muted relative block aspect-video w-full overflow-hidden">
      <img
        src={video.thumbnail}
        alt={video.title}
        width="480"
        height="360"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        data-fallback-src={thumbnailFallback}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
      <span
        class="bg-scrim/15 group-hover:bg-scrim/25 group-focus-visible:bg-scrim/25 absolute inset-0 flex items-center justify-center opacity-0 transition-all duration-200 group-hover:opacity-100 group-focus-visible:opacity-100"
        aria-hidden="true"
      >
        <IconBadge
          tone="soft"
          size="lg"
          style={{
            '--ui-icon-badge-accent': 'var(--channel-active-accent)',
            '--ui-icon-badge-foreground': 'var(--channel-active-accent-dark)',
          }}
          class="shadow-md"
        >
          <Icon
            name="heroicons:play-solid"
            class="size-5 translate-x-[1px]"
            aria-hidden="true"
          />
        </IconBadge>
      </span>
    </span>

    <span class="block px-5 py-5 sm:px-6 sm:py-6">
      <span class="mb-5 flex min-w-0 items-center gap-3">
        <span
          class:list={[
            'grid size-11 shrink-0 place-items-center overflow-hidden rounded-full bg-[var(--channel-active-logo-bg)] ring-2 ring-[color-mix(in_srgb,var(--channel-active-accent)_35%,transparent)]',
            channelLogoPaddingClass,
          ]}
        >
          <img
            src={channelLogoSrc}
            alt={channelName}
            width="44"
            height="44"
            loading="lazy"
            decoding="async"
            class:list={[
              'h-full w-full',
              channelLogoFit === 'contain' ? 'object-contain' : 'object-cover',
            ]}
          />
        </span>
        <span class="min-w-0">
          <span
            class="ui-kicker-accent block tracking-[0.08em] text-[var(--channel-active-accent)]"
          >
            Latest from the channel
          </span>
          <span
            class="ui-meta block truncate text-foreground"
          >
            {channelName}
          </span>
        </span>
      </span>

      <span
        class="ui-card-title mb-3 block sm:text-xl"
      >
        {video.title}
      </span>

      <span class="ui-body mb-5 block text-sm">
        {channelDescription}
      </span>

      <span
        class="text-primary-foreground mb-5 inline-flex items-center gap-2 rounded-full bg-[var(--channel-active-accent)] px-4 py-2 text-sm font-semibold whitespace-nowrap shadow-sm transition-all duration-200 group-hover:translate-x-0.5 group-hover:shadow-md"
      >
        Latest episode
        <Icon
          name="heroicons:arrow-top-right-on-square"
          class="size-4"
          aria-hidden="true"
        />
      </span>

      {
        publishedDate && (
          <span class="ui-meta block text-muted-foreground/75 font-normal">
            Published {publishedDate}
          </span>
        )
      }
    </span>
  </a>
</div>
